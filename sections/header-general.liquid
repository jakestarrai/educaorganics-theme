{%- comment -%}
  This is a required section for the Shopify Theme Store.
  It is available in the "Header" section in the theme editor.

  Theme Store required settings
  - Show announcement
  - Text: message to announce
  - Link: link of the announcement bar

  Theme Store optional settings
  - Home page only: only shows on the home page
{%- endcomment -%}

<header id="header">
  {% render 'header-announcement' %}

  <div
    class="sticky-wrap-header__panel group/sticky-wrapper relative"
    data-sticky-states
    data-sticky-container="body"
  >
    <div
      class="
        header__panel
        z-100
        bg-base-body-background
        py-5
        transition-transform
        duration-200
        ease-in-out
        group-[.fixed-position]/sticky-wrapper:fixed
        group-[.fixed-position]/sticky-wrapper:left-0
        group-[.fixed-position]/sticky-wrapper:top-0
        group-[.fixed-position]/sticky-wrapper:!w-full
        group-[.megamenu-open]/html:!translate-y-0
        group-[.nav-up]/sticky-wrapper:translate-y-[-100%]
        xl:relative
        xl:py-0
        xl:group-[.fixed-position]/sticky-wrapper:z-1001
        {% if section.settings.enable_shadow %}
        shadow-md
        {% endif %}
      "
      data-sticky-states-inner
    >
      <div class="container max-w-screen-3xl">
        <div class="flex items-center justify-between">
          <div class="
              group/header-column
              hidden
              w-1/2
              xl:flex
              {% if section.settings.layout == 'center' %}
              xl:w-4/12
              {% else %}
              xl:order-2
              xl:w-6/12
              xl:justify-center
              {% endif %}
            ">
            {% if section.settings.menu_desktop != blank %}
              <nav
                class="hidden xl:block"
                aria-label="Main navigation"
              >
                <ul
                  id="nav"
                  class="
                    menu-accordion
                    tracking-wider
                    xl:-ml-3
                    xl:flex
                    xl:flex-wrap
                    xl:items-center
                    xl:gap-y-2
                    xl:group-[.justify-center]/header-column:ml-0
                    xl:group-[.justify-center]/header-column:justify-center
                  "
                >
                  {% render 'nav-menu-desktop' %}
                </ul>
              </nav>
            {% endif %}
          </div>
          <div class="
              group/logo-holder
              w-2/3
              {% if section.settings.layout == 'center' %}
              xl:w-4/12
              {% else %}
              xl:order-1
              xl:flex
              xl:w-3/12
              xl:flex-wrap
              xl:items-center
              xl:justify-start
              xl:py-5
              {% endif %}
            ">
            {% liquid
              if section.settings.enable_lazyload
                assign enable_lazyload = true
                assign fetchpriority_value = 'low'
              else
                assign enable_lazyload = false
                assign fetchpriority_value = 'high'
              endif
            %}
            {% render 'header-logo', enable_lazyload: enable_lazyload, fetchpriority_value: fetchpriority_value %}
          </div>
          <div class="
              -mr-1
              flex
              w-1/3
              items-center
              justify-end
              xl:mr-0
              xl:py-5
              {% if section.settings.layout == 'center' %}
              xl:w-4/12
              {% else %}
              xl:order-3
              xl:w-3/12
              {% endif %}
            ">
            {% if section.settings.button_link != blank %}
              <div class="hidden xl:inline-block">
                {%
                  render 'button',
                  href: section.settings.button_link,
                  color: 'primary',
                  size: 'md',
                  text: section.settings.button_label
                %}
              </div>
            {% endif %}
            {% render 'header-icons' %}
            <div class="menu ml-2 xl:ml-0">
              <div class="flex items-center xl:hidden">
                {% if section.settings.menu != blank %}
                  <button class="
                      menu__opener
                      page-wrapper__opener
                      relative
                      block
                      h-10
                      w-10
                      shrink-0
                      text-[0]
                      leading-[0]
                      before:absolute
                      before:left-[20%]
                      before:right-[20%]
                      before:top-[30%]
                      before:h-[2px]
                      before:rounded-sm
                      before:bg-base-body
                      before:content-['']
                      after:absolute
                      after:left-[20%]
                      after:right-[20%]
                      after:top-[70%]
                      after:h-[2px]
                      after:rounded-sm
                      after:bg-base-body
                      after:content-['']
                    ">
                    <span class="
                        absolute
                        left-[20%]
                        right-[20%]
                        top-1/2
                        h-[2px]
                        rounded-sm
                        bg-base-body
                      ">
                      Menu
                    </span>
                  </button>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% render 'header-general-menu-dropdown' %}
</header>

<style>
  .header__bar {
    {% if section.settings.announcement_bar_bg_color != blank and section.settings.announcement_bar_bg_color.alpha != 0 %}
      background: {{ section.settings.announcement_bar_bg_color }} !important;
    {% endif %}
    {% if section.settings.announcement_bar_text_color != blank and section.settings.announcement_bar_text_color.alpha != 0 %}
      color: {{ section.settings.announcement_bar_text_color }} !important;
    {% endif %}
  }

  .header__panel--dark {
    background: #000;
    color: #fff
  }

  .header__panel--dark .menu__opener span,
  .header__panel--dark .menu__opener::before,
  .header__panel--dark .menu__opener::after {
      background: #fff;
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "checkbox",
      "id": "announcement_bar_enabled",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "announcement_bar_home_page_only",
      "label": "Show on home page only",
      "default": false
    },
    {
      "type": "text",
      "id": "announcement_bar_text",
      "label": "Announcement text",
      "default": "Announce something here"
    },
    {
      "type": "url",
      "id": "announcement_bar_link",
      "label": "Announcement link",
      "info": "Optional"
    },
    {
      "type": "color",
      "id": "announcement_bar_bg_color",
      "label": "Announcement bar bg color",
      "default": "#000"
    },
    {
      "type": "color",
      "id": "announcement_bar_text_color",
      "label": "Announcement bar text color",
      "default": "#fff"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "logo_svg",
      "label": "SVG logo",
      "default": "logo-2.svg",
      "info": "Grabs image from assets example (logo.svg including file extension)"
    },
    {
      "type": "range",
      "id": "logo_svg_width",
      "label": "Logo svg width",
      "min": 100,
      "max": 200,
      "step": 1,
      "default": 175
    },
    {
      "type": "range",
      "id": "logo_svg_height",
      "label": "Logo svg height",
      "min": 20,
      "max": 100,
      "step": 1,
      "default": 24
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "checkbox",
      "id": "enable_lazyload",
      "label": "Enable lazyload",
      "default": true
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Draft"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu mobile",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "menu_desktop",
      "label": "Menu Desktop",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Logo alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "search_enable",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_search_form",
      "label": "Show search form on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "cart_enable",
      "label": "Show cart icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_account_icon",
      "label": "Show account icon",
      "default": false
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Button is disabled if empty"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Submit an inquiry"
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "label": "Enable shadow effect",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "Megamenu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Menu item"
        },
        {
          "type": "header",
          "content": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading_1",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text_1",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "block_url_1",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading_2",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text_2",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "block_url_2",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Image 3"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading_3",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text_3",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "block_url_3",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Image 4"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading_4",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text_4",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "block_url_4",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Image 5"
        },
        {
          "type": "image_picker",
          "id": "image_5",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading_5",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text_5",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "block_url_5",
          "label": "Link"
        }
      ]
    }
  ]
}
{% endschema %}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": "{{ shop.name }}",
    {% if section.settings.logo %}
      "logo": "https:{{ section.settings.logo | image_url: width: section.settings.logo.width }}",
    {% endif %}
    "sameAs": [
      "{{ settings.social_twitter_link }}",
      "{{ settings.social_facebook_link }}",
      "{{ settings.social_pinterest_link }}",
      "{{ settings.social_instagram_link }}",
      "{{ settings.social_tumblr_link }}",
      "{{ settings.social_snapchat_link }}",
      "{{ settings.social_youtube_link }}",
      "{{ settings.social_vimeo_link }}"
    ],
    "url": "{{ shop.url }}{{ page.url }}"
  }
</script>

{% if template.name == 'index' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": "{{ shop.name }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ shop.url }}/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "url": "{{ shop.url }}{{ page.url }}"
    }
  </script>
{% endif %}
