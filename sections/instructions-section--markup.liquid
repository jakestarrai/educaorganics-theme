            <h3 class="
                mb-4
                font-heading
                text-h2
                last:mb-0
                lg:mb-6
                lg:text-h2-desktop
              ">
              Live it.
            </h3>
            <div class="
                prose
                mb-4
                text-body-xs
                last:mb-0
                lg:mb-6
                lg:text-body-small
              ">
              <p>The day’s yours for the taking. What’s on the cards?</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
