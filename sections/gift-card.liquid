{% comment %}
  QR code is rendered in `#QrCode`

  `gift_card.pass_url` is true if apple wallet is enabled for the shop
{% endcomment %}

{% layout 'gift_card' %}

<header class="pb-5 pt-10">
  <div class="container max-w-screen-3xl">
    {% if section.settings.logo_svg != blank %}
      <div class="mx-auto h-auto max-w-[var(--header-logo-width)]">
        <a
          href="{{ routes.root_url }}"
          class="block h-full"
          rel="nofollow"
        >
          <img
            src="{{ section.settings.logo_svg | asset_url }}"
            class="block w-full"
            width="86"
            height="18"
            alt="Draft logo"
            loading="eager"
            fetchpriority="high"
          >
        </a>
      </div>
    {% elsif section.settings.logo != blank %}
      <div class="mx-auto h-auto max-w-[var(--header-logo-width)]">
        <a
          href="{{ routes.root_url }}"
          class="block h-full"
          rel="nofollow"
        >
          <img
            src="{{ section.settings.logo | image_url: width: 172 }}"
            width="{{ section.settings.logo.width }}"
            height="{{ section.settings.logo.width | divided_by: section.settings.logo.aspect_ratio | floor }}"
            alt="{{ section.settings.logo.alt | default: "Draft logo" }}"
          >
        </a>
      </div>
    {% else %}
      <div class="px-3 text-center text-h4 lg:text-h4-desktop">
        <a
          href="{{ routes.root_url }}"
          class="text-inherit no-underline"
          rel="nofollow"
        >
          {{ section.settings.logo_text }}
        </a>
      </div>
    {% endif %}
  </div>
</header>

<div class="giftcard pb-10">
  <div class="container max-w-screen-3xl">
    <div class="text-center md:mx-auto md:w-8/12">
      <h1 class="mb-5 font-heading text-h5">
        {{ 'gift_cards.issued.subtext' | t }}
      </h1>
      <div class="mb-5 text-product-price-large lg:text-product-price-large-desktop">
        {% unless gift_card.enabled %}
          <span>{{ 'gift_cards.issued.disabled' | t }}</span>
        {% endunless %}

        {%- assign gift_card_expiry_date = gift_card.expires_on | date: "%d/%m/%y" -%}

        {% if gift_card.expired and gift_card.enabled %}
          <span>{{ 'gift_cards.issued.expired' | t: expiry: gift_card_expiry_date }}</span>
        {% endif %}

        {% if gift_card.expired != true and gift_card.expires_on and gift_card.enabled %}
          <span>
            {{- 'gift_cards.issued.active' | t: expiry: gift_card_expiry_date -}}
          </span>
        {% endif %}

        {% assign formatted_initial_value = gift_card.initial_value | money_without_trailing_zeros: gift_card.currency %}

        {{ 'gift_cards.issued.initial_value' | t: value: formatted_initial_value }}

        {% assign formatted_current_balance = gift_card.balance | money %}

        {% if gift_card.balance != gift_card.initial_value %}
          <p>{{ 'gift_cards.issued.remaining_html' | t: balance: formatted_current_balance }}</p>
        {% endif %}
      </div>

      <div class="
          gift-card-image-wrapper
          {{ section.settings.qrcode_position }}
          group
          relative
          mx-auto
          mb-5
          w-[345px]
          md:w-[520px]
        ">
        <div class="mb-5">
          {%- if section.settings.image_card != blank -%}
            <img
              src="{{ section.settings.image_card | image_url: width: 520 }}"
              width="{{ section.settings.image_card.width }}"
              height="{{ section.settings.image_card.width | divided_by: section.settings.image_card.aspect_ratio | floor }}"
              alt="{{ section.settings.image_card.alt | default: "Gift card illustration" }}"
            >
          {%- else -%}
            <img
              src="{{ 'gift-card/card.jpg' | shopify_asset_url }}"
              width="520"
              height="346"
              alt="Gift card illustration"
            >
          {%- endif -%}
        </div>

        <div class="
            gift-card__qr-code
            mx-auto
            mt-5
            h-32
            w-32
            group-[&.gift-card-image-wrapper--alt]:absolute
            group-[&.gift-card-image-wrapper--alt]:left-1/2
            group-[&.gift-card-image-wrapper--alt]:top-1/2
            group-[&.gift-card-image-wrapper--alt]:m-0
            group-[&.gift-card-image-wrapper--alt]:h-[155px]
            group-[&.gift-card-image-wrapper--alt]:w-[155px]
            group-[&.gift-card-image-wrapper--alt]:-translate-x-1/2
            group-[&.gift-card-image-wrapper--alt]:-translate-y-1/2
            group-[&.gift-card-image-wrapper--alt]:rounded-md
            group-[&.gift-card-image-wrapper--alt]:bg-white
            group-[&.gift-card-image-wrapper--alt]:p-3
            md:h-40
            md:w-40
          ">
          <div
            id="QrCode"
            class="giftcard-qr [&>img]:w-full"
          ></div>
        </div>
      </div>

      <div
        id="GiftCardDigits"
        class="mb-3 md:mx-auto md:w-[345px]"
        data-gift-card-digits
      >
        <input
          type="text"
          class="
            gift-card__number
            form-input
            h-form-element
            w-full
            rounded-form-element
            bg-base-body-background
            text-center
            text-body-large
            placeholder:text-base-secondary
            autofill:shadow-inset-white
          "
          value="{{ gift_card.code | format_code }}"
          aria-label="{{ 'gift_cards.issued.gift_card_code' | t }}"
          readonly
        >
      </div>

      <div class="mb-3">
        <button class="gift-card__copy-link text-link underline hover:no-underline focus:no-underline">
          {{ 'gift_cards.issued.copy_code_text' | t }}
        </button>
        <div
          class="
            gift-card__copy-success
            mt-2
            flex
            items-center
            justify-center
            text-body-small
          "
          role="status"
        >
          <template>
            {%- render 'icon', icon: 'success', class: 'shrink-0 w-5 h-5 mr-2' -%}
            {{ 'gift_cards.issued.copy_code_success' | t }}
          </template>
        </div>
      </div>
      {% if gift_card.pass_url %}
        <a
          href="{{ gift_card.pass_url }}"
          class="mb-3 inline-block"
        >
          <img
            src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
            width="120"
            height="40"
            alt="{{ 'gift_cards.issued.add_to_apple_wallet' | t }}"
          >
        </a>
      {% endif %}
      <div class="mb-5 last:mb-0">
        {%
          render 'button',
          href: routes.root_url,
          class: "min-w-full md:min-w-[240px]",
          color: 'secondary',
          size: 'md',
          locales_text: 'gift_cards.issued.shop_link',
          data_attribute: 'rel="nofollow" target="_blank"'
        %}
      </div>
      <div class="mb-5 last:mb-0">
        {%
          render 'button',
          element: 'button',
          class: 'min-w-full md:min-w-[240px]',
          color: 'primary',
          size: 'md',
          locales_text: 'gift_cards.issued.print',
          data_attribute: 'data-gift-card-print id="PrintGiftCard"',
          other: 'onclick="window.print();"'
        %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Gift card",
  "settings": [
    {
      "type": "text",
      "id": "logo_svg",
      "label": "SVG logo",
      "default": "logo-2.svg"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text"
    },
    {
      "type": "image_picker",
      "id": "image_card",
      "label": "Image card"
    },
    {
      "type": "select",
      "id": "qrcode_position",
      "label": "Qr Code position",
      "options": [
        {
          "value": "gift-card-image-wrapper--alt",
          "label": "On image"
        },
        {
          "value": "",
          "label": "Under image"
        }
      ]
    }
  ]
}
{% endschema %}

<script>
  let template = document.getElementsByTagName("template")[0];
  let clonedTemplate = template.content.cloneNode(true);
  let isMessageDisplayed = false

  document
    .querySelector('.gift-card__copy-link')
    .addEventListener('click', () => {
      navigator.clipboard.writeText(document.querySelector('.gift-card__number').value).then(function () {
        if (!isMessageDisplayed) {
          document.querySelector('.gift-card__copy-success').appendChild(clonedTemplate);
          isMessageDisplayed = true
        }
      });
    });

  document.addEventListener('DOMContentLoaded', function() {
    new QRCode(document.getElementById('QrCode'), {
      text: '{{ gift_card.qr_identifier }}',
      width: 120,
      height: 120,
    });
  });
</script>
