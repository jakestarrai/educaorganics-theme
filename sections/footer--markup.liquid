<style>
  [id="footer"] {
    background: var(--base-footer-background) url({{'footer-bg.jpg' | asset_url}}) repeat;
  }
</style>

<footer
  id="footer"
  class="bg-base-footer-background pb-6 pt-16 text-white lg:py-10"
>
  <div class="container max-w-screen-3xl">
    <div class="flex flex-col lg:flex-row-reverse lg:gap-20 2xl:pr-20">
      <div class="flex flex-col lg:w-full">
        <div class="flex flex-col lg:flex-row-reverse lg:pb-45 lg:pt-10">
          <div class="
              border-b-2
              border-base-accent
              pb-12
              lg:w-[58.5%]
              lg:border-none
              lg:pb-0
            ">
            <div class="mb-7 text-base-accent">
              <h3 class="
                  mb-2
                  font-heading
                  text-h1
                  lg:mb-4
                  lg:text-h2-desktop
                ">
                Join the club.
              </h3>
              <div class="prose text-body-xs lg:text-body-medium [&_a]:text-inherit">
                <p>
                  Get 10% off when you sign up for our newsletter.
                  <a href="#">Boom</a>
                  !
                </p>
              </div>
            </div>

            {% form 'customer', novalidate: 'novalidate', class: 'mb-9' %}
              <fieldset>
                <legend class="sr-only">Join form</legend>
                <input
                  type="hidden"
                  name="contact[tags]"
                  value="newsletter"
                >
                <label
                  for="newsletter-form-email-field"
                  class="sr-only"
                >
                  {{ 'general.newsletter_form.please_enter_your_email' | t }}
                </label>
                <div class="relative flex items-center gap-4">
                  <input
                    type="email"
                    id="newsletter-form-email-field"
                    class="
                      placeholder:text-base-body/[0.5]
                      form-input
                      h-12
                      w-full
                      rounded-xl
                      border-white
                      bg-white
                      px-4
                      text-body-xs
                      text-base-body
                      autofill:shadow-inset-white
                      focus:border-base-accent
                      lg:h-16
                      lg:px-6
                      lg:text-body-small
                    "
                    name="contact[email]"
                    inputmode="email"
                    placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}"
                  >
                  <button
                    type="submit"
                    class="
                      group
                      relative
                      flex
                      h-12
                      w-12
                      shrink-0
                      items-center
                      justify-center
                      text-base-accent
                      lg:h-16
                      lg:w-16
                    "
                  >
                    <span class="sr-only">Button submit</span>
                    {%-
                      render 'icon',
                      icon: 'arrow-right-circle',
                      class: '
                      w-12
                      h-12
                      group-hover:opacity-0
                      group-focus:opacity-0
                      lg:w-16
                      lg:h-16
                      lg:duration-300
                      lg:transition-opacity
                      lg:ease-in-out'
                    -%}
                    {%-
                      render 'icon',
                      icon: 'arrow-right-circle-filled',
                      class: '
                      absolute
                      left-1/2
                      top-1/2
                      h-full
                      w-full
                      -translate-x-[50%]
                      -translate-y-[50%]
                      opacity-0
                      group-hover:opacity-100
                      group-focus:opacity-100
                      lg:duration-300
                      lg:transition-opacity
                      lg:ease-in-out'
                    -%}
                  </button>
                </div>
                {%- comment -%}form success message{%- endcomment -%}
                {%- if form.posted_successfully? -%}
                {%- endif -%}
                <div
                  class="relative flex items-center gap-4 text-base-accent"
                  data-form-status
                >
                  <div class="
                      min-h-12
                      w-full
                      rounded-xl
                      border-2
                      border-base-accent
                      px-4
                      py-3
                      font-heading
                      text-h4
                      lg:min-h-16
                      lg:p-4
                      lg:text-h4-desktop
                    ">
                    {{ 'general.newsletter_form.confirmation' | t }}
                  </div>
                  <div>
                    {%- render 'icon', icon: 'form-success', class: 'h-12 w-12 lg:h-16 lg:w-16' -%}
                  </div>
                </div>
              </fieldset>
            {% endform %}

            <div class="flex flex-wrap gap-6 text-base-accent">
              <ul class="footer-social-list flex flex-wrap gap-4">
                <li>
                  <a href="#">
                    {%- render 'icon', icon: 'instagram', class: 'h-6 w-6' -%}
                  </a>
                </li>
                <li>
                  <a href="#">
                    {%- render 'icon', icon: 'tiktok', class: 'h-6 w-6' -%}
                  </a>
                </li>
                <li>
                  <a href="#">
                    {%- render 'icon', icon: 'facebook', class: 'h-6 w-6' -%}
                  </a>
                </li>
              </ul>

              <div class="[&_a:focus]:underline [&_a:hover]:underline">
                <a href="mailto:hello@educaorganics.com">hello@educaorganics.com</a>
              </div>
            </div>
          </div>

          <div class="flex gap-12 py-12 lg:w-[41.5%] lg:py-0">
            <div class="w-28 md:w-24 lg:hidden">
              {% render 'footer-logo' %}
            </div>

            <div class="flex flex-col gap-9 md:flex-row">
              <div class="md:max-w-[140px]">
                <div class="
                    mb-6
                    font-heading
                    text-caps-s
                    uppercase
                    lg:text-h6
                  ">
                  shop
                </div>
                <nav aria-label="Shop navigation">
                  <ul class="grid gap-[2px] [&_a:focus]:underline [&_a:hover]:underline">
                    <li>
                      <a href="#">All Products</a>
                    </li>
                    <li>
                      <a href="#">Women's Daily</a>
                    </li>
                    <li>
                      <a href="#">Men's Daily</a>
                    </li>
                    <li>
                      <a href="#">Fitness + Recovery</a>
                    </li>
                    <li>
                      <a href="#">Balance + Relief</a>
                    </li>
                    <li>
                      <a href="#">Travel + Defense</a>
                    </li>
                  </ul>
                </nav>
              </div>

              <div class="
                  flex
                  flex-col
                  gap-10
                  md:flex-row
                  md:flex-wrap
                  lg:max-w-[140px]
                  lg:flex-col
                ">
                <div>
                  <div class="
                      mb-6
                      font-heading
                      text-caps-s
                      uppercase
                      lg:text-h6
                    ">
                    learn
                  </div>
                  <nav aria-label="Learn navigation">
                    <ul class="grid gap-[2px] [&_a:focus]:underline [&_a:hover]:underline">
                      <li>
                        <a href="#">Our Mission</a>
                      </li>
                      <li>
                        <a href="#">The Science</a>
                      </li>
                    </ul>
                  </nav>
                </div>

                <div>
                  <div class="
                      mb-6
                      font-heading
                      text-caps-s
                      uppercase
                      lg:text-h6
                    ">
                    help
                  </div>
                  <nav aria-label="Help navigation">
                    <ul class="grid gap-[2px] [&_a:focus]:underline [&_a:hover]:underline">
                      <li>
                        <a href="#">FAQs</a>
                      </li>
                      <li>
                        <a href="#">Privacy Policy</a>
                      </li>
                      <li>
                        <a href="#">Terms / Legal</a>
                      </li>
                    </ul>
                  </nav>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col lg:w-full lg:flex-col-reverse lg:gap-10">
          <div class="
              border-t-2
              border-base-accent
              py-6
              text-body-xs
              lg:pb-0
              lg:text-body-small
            ">
            <div class="
                flex
                items-center
                justify-between
                [&_a:focus]:no-underline
                [&_a:hover]:no-underline
                [&_a]:underline
              ">
              <div class="max-w-1/2">© EDUCA Organics 2026</div>
              <div class="max-w-1/2">
                Site by
                <a href="/">ONBOX</a>
              </div>
            </div>
          </div>
          <div class="text-body-xs opacity-50 lg:ml-auto lg:w-[58.5%]">
            <p>
              * These statements have not been evaluated by the Food and Drug Administration. Our products are not
              intended to diagnose, treat, cure, or prevent any disease.
            </p>
          </div>
        </div>
      </div>

      <div class="hidden lg:block lg:w-[132px] lg:shrink-0">
        {% render 'footer-logo' %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_svg",
      "label": "SVG logo",
      "default": "footer-logo.svg",
      "info": "Grabs image from assets example (logo.svg including file extension)"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Draft"
    }
  ]
}
{% endschema %}
