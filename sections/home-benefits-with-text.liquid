<section class="py-10 md:overflow-hidden">
  <div class="container max-w-screen-3xl">
    <div class="lg:mx-auto lg:w-10/12">
      <div class="grid gap-4 md:grid-flow-col md:grid-cols-2">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when "title" %}
              <div
                class="
                  md:[&:nth-child(3)]:row-span-3
                  md:[&:nth-child(3)]:flex
                  md:[&:nth-child(3)]:flex-col
                  md:[&:nth-child(3)]:flex-wrap
                  md:[&:nth-child(3)]:justify-center
                "
                {{ block.shopify_attributes }}
              >
                <h2 class="font-heading text-h2 lg:text-h2-desktop">
                  {{ block.settings.title }}
                </h2>
              </div>
            {% when "text" %}
              <div
                class="
                  prose
                  md:[&:nth-child(3)]:row-span-3
                  md:[&:nth-child(3)]:flex
                  md:[&:nth-child(3)]:flex-col
                  md:[&:nth-child(3)]:flex-wrap
                  md:[&:nth-child(3)]:justify-center
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {% when "html" %}
              <div
                class="
                  prose
                  md:[&:nth-child(3)]:row-span-3
                  md:[&:nth-child(3)]:flex
                  md:[&:nth-child(3)]:flex-col
                  md:[&:nth-child(3)]:flex-wrap
                  md:[&:nth-child(3)]:justify-center
                "
                {{ block.shopify_attributes }}
              >
                {{ block.settings.html }}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits with text",
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Unlimited Phone Data\" Is Not \"Unlimited Home Data"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Body text",
          "default": "<p>Purus ut faucibus pulvinar elementum integer. Lorem mollis aliquam ut porttitor leo a diam sollicitudin. Molestie ac feugiat sed lectus vestibulum mattis ullamcorper velit.</p>"
        }
      ]
    },
    {
      "type": "html",
      "name": "HTML",
      "limit": 1,
      "settings": [
        {
          "type": "html",
          "id": "html",
          "label": "HTML",
          "default": "<ul class=\"list-checks pl-8\">\n                <li>Unlimited Wi-Fi for EVERY connected device</li>\n                <li>14 Day, No Risk, Money-Back Guarantee</li>\n                <li>Human Support</li>\n                <li>Rich Documentation</li>\n                <li>Unlimited Phone Data</li>\n              </ul>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits with text",
      "category": "Text"
    }
  ]
}
{% endschema %}
