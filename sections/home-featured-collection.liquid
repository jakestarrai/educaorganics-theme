{% liquid
  assign collection = collections[section.settings.collection]
  assign product_limit = section.settings.product_limit

  assign image_sizes_mobile = '184x'
  assign image_sizes_desktop = '360x'
%}

<link
  rel="stylesheet"
  href="{{ 'splide-gallery.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{% capture section_content %}
  <div class="container max-w-screen-3xl xl:px-20">
    <div class="
        flex
        flex-col
        gap-6
        text-center
        lg:mb-10
        lg:flex-row
        lg:items-end
        lg:justify-between
        lg:gap-20
        lg:text-left
      ">
      <div class="lg:w-6/12">
        {% if section.settings.heading != blank %}
          <div class="
              mb-4
              text-caps-s
              uppercase
              last:mb-0
              lg:mb-6
              lg:font-heading
              lg:text-h6
            ">
            {{ section.settings.heading }}
          </div>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="
              mb-4
              font-heading
              text-h2
              last:mb-0
              lg:text-h1-desktop
            ">
            {{ section.settings.title }}
          </h2>
        {% endif %}
      </div>
      {% if section.settings.text != blank %}
        <div class="prose lg:w-2/5">
          {{ section.settings.text }}
        </div>
      {% endif %}
    </div>

    <div
      class="
        featured-collection-gallery
        splide
        group/slider
        -mr-6
        pt-10
        md:py-10
        lg:-mr-20
        lg:gap-10
      "
      id="product-gallery-{{ section.id }}"
    >
      <div class="splide__track mb-10">
        <div class="splide__list flex">
          {% liquid
            for product in collection.products limit: product_limit
              if section.settings.enable_lazyload
                assign enable_lazyload = true
                assign fetchpriority_value = 'low'
              elsif section.settings.enable_lazyload == false and forloop.first
                assign enable_lazyload = false
                assign fetchpriority_value = 'high'
              else
                assign enable_lazyload = true
                assign fetchpriority_value = 'low'
              endif

              render "product-card", product: product, grid_item_width: '', classes: 'splide__slide', image_sizes_mobile: image_sizes_mobile, image_sizes_desktop: image_sizes_desktop, show_vendor: section.settings.show_vendor, enable_lazyload: enable_lazyload, image_ratio: section.settings.image_ratio, fetchpriority_value: fetchpriority_value
            else
              for i in (1..product_limit)
                capture current
                  cycle 1, 2, 3, 4, 5, 6
                endcapture
                assign current_index = current | strip
                assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1
                assign placeholder_image = 'product-apparel-' | append: placeholder_image_index
                render "product-card--empty", index: current_index, grid_item_width: '', classes: 'splide__slide', image_sizes_mobile: image_sizes_mobile, image_sizes_desktop: image_sizes_desktop, image_ratio: section.settings.image_ratio, placeholder_image: placeholder_image
              endfor
            endfor
          %}
        </div>
      </div>

      <div
        class="splide__progress"
        aria-hidden="true"
      >
        <div class="splide__progress-bar"></div>
      </div>
    </div>

    {%- if section.settings.show_view_all and collection != blank -%}
      {% assign button_label = 'collections.general.view_all' | t %}
      <div class="pt-8 text-center">
        {%
          render 'button',
          href: collection.url,
          color: 'primary',
          size: 'md',
          text: button_label
        %}
      </div>
    {%- endif -%}
  </div>
{% endcapture %}

{% if section.settings.title != blank %}
  <section
    class="overflow-hidden py-16 lg:pb-0 lg:pt-30"
    id="product-gallery-section-{{ section.id }}"
    data-section-type="product-gallery"
    data-section-id="{{ section.id }}"
    data-blocks="{{ section.blocks.size }}"
    aria-label="Featured Collection Gallery"
  >
    {{ section_content }}
  </section>
{% else %}
  <div
    class="overflow-hidden py-16 lg:pb-0 lg:pt-30"
    id="product-gallery-section-{{ section.id }}"
    data-section-type="product-gallery"
    data-section-id="{{ section.id }}"
    data-blocks="{{ section.blocks.size }}"
    role="group"
    aria-label="Featured Collection Gallery"
  >
    {{ section_content }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "STEP UP YOUR GUT GAME"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Whether you’re wandering the globe or working out hard, there’s a precision infant formula to suit your daily needs.</p>"
    },
    {
      "id": "collection",
      "type": "collection",
      "label": "Collection"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "Adapt to image"
        },
        {
          "value": "product-item--portrait",
          "label": "Portrait"
        },
        {
          "value": "product-item--square",
          "label": "Square"
        }
      ]
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Product limit",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "enable_lazyload",
      "label": "Enable lazyload",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "category": "Collection"
    }
  ]
}
{% endschema %}
