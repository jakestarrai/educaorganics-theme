<section class="py-10">
  <div class="container max-w-screen-3xl">
    <div class="mb-10 text-center [&>*:last-child]:mb-0">
      <h1 class="font-heading text-h4 lg:text-h4-desktop">{{ 'customer.register.title' | t }}</h1>
    </div>
    {% form 'create_customer', class: 'account-form max-w-[450px] mx-auto text-base-body' %}
      {{ form.errors | default_errors }}
      <div class="mb-5">
        <label
          class="mb-1 inline-block"
          for="first-name"
        >
          {{ 'customer.register.first_name' | t }}
        </label>
        <input
          type="text"
          id="first-name"
          class="
            form-input
            h-form-element
            w-full
            rounded-form-element
            border-base-border
            bg-base-body-background
            text-body-medium
            placeholder:text-base-secondary
            autofill:shadow-inset-white
            focus:border-base-body
          "
          name="customer[first_name]"
          placeholder="{{ 'customer.register.first_name' | t }}"
          {% if form.first_name %}
            value="{{ form.first_name }}"
          {% endif %}
        >
      </div>
      <div class="mb-5">
        <label
          class="mb-1 inline-block"
          for="last-name"
        >
          {{ 'customer.register.last_name' | t }}
        </label>
        <input
          type="text"
          id="last-name"
          class="
            form-input
            h-form-element
            w-full
            rounded-form-element
            border-base-border
            bg-base-body-background
            text-body-medium
            placeholder:text-base-secondary
            autofill:shadow-inset-white
            focus:border-base-body
          "
          name="customer[last_name]"
          placeholder="{{ 'customer.register.last_name' | t }}"
          {% if form.last_name %}
            value="{{ form.last_name }}"
          {% endif %}
        >
      </div>
      <div class="mb-5">
        <label
          class="mb-1 inline-block"
          for="email"
        >
          {{ 'customer.register.email' | t }}
        </label>
        <input
          type="email"
          id="email"
          class="
            {% if form.errors contains 'email' %}input-error{% endif %}
            form-input
            h-form-element
            w-full
            rounded-form-element
            border-base-border
            bg-base-body-background
            text-body-medium
            placeholder:text-base-secondary
            autofill:shadow-inset-white
            focus:border-base-body
          "
          name="customer[email]"
          placeholder="{{ 'customer.register.email' | t }}"
          value="{% if form.email %}{{ form.email }}{% endif %}"
          spellcheck="false"
          autocomplete="off"
          autocapitalize="off"
        >
      </div>
      <div class="mb-5">
        <label
          class="mb-1 inline-block"
          for="create-password"
        >
          {{ 'customer.register.password' | t }}
        </label>
        <input
          type="password"
          id="create-password"
          class="
            {% if form.errors contains 'password' %}input-error{% endif %}
            form-input
            h-form-element
            w-full
            rounded-form-element
            border-base-border
            bg-base-body-background
            text-body-medium
            placeholder:text-base-secondary
            autofill:shadow-inset-white
            focus:border-base-body
          "
          name="customer[password]"
          placeholder="{{ 'customer.register.password' | t }}"
        >
      </div>
      {% if settings.enable_accept_marketing %}
        <div class="mb-5 inline-flex items-center">
          <input
            type="hidden"
            name="customer[accepts_marketing]"
            value="false"
          >
          <input
            type="checkbox"
            id="accepts-marketing"
            class="
              peer
              form-checkbox
              mr-2
              h-6
              w-6
              shrink-0
              rounded-form-element
              border-base-border
              bg-base-body-background
              text-base-body
              checked:bg-[length:75%_75%]
              focus:ring-0
              focus:ring-opacity-0
              focus:ring-offset-0
              focus:ring-offset-transparent
              disabled:bg-base-accent
            "
            name="customer[accepts_marketing]"
          >
          <label
            class="peer-disabled:text-base-secondary"
            for="accepts-marketing"
          >
            {{- 'customer.register.accepts-marketing' | t -}}
          </label>
        </div>
      {% endif %}
      <div class="mb-5">
        {%
          render 'button',
          element: 'input',
          type: 'submit',
          class: 'w-full',
          size: 'md',
          color: 'primary',
          locales_text: 'customer.register.submit'
        %}
      </div>
      <div class="py-3 text-center text-body-small">
        <a
          href="{{ routes.root_url }}"
          rel="nofollow"
          class="no-underline hover:underline"
        >
          {{- 'customer.register.cancel' | t -}}
        </a>
      </div>
    {% endform %}
  </div>
</section>
