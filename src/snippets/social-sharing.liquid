<!-- /snippets/social-sharing.liquid -->
<ul class="
    mb-6
    flex
    flex-wrap
    items-center
    gap-4
    text-body-small
    last:mb-0
  ">
  {% if settings.share_facebook %}
    <li>
      <a
        target="_blank"
        href="//www.facebook.com/sharer.php?u={{ shop.url | append: share_permalink }}"
        rel="noopener"
        class="flex items-center text-base-body"
      >
        <div class="mr-3 w-5 shrink-0">
          {% render 'icon-facebook' %}
        </div>
        Share
      </a>
    </li>
  {% endif %}
  {% if settings.share_twitter %}
    <li>
      <a
        target="_blank"
        href="//twitter.com/share?text={{ share_title | url_param_escape }}&amp;url={{ shop.url | append: share_permalink }}"
        rel="noopener"
        class="flex items-center text-base-body"
      >
        <div class="mr-3 w-5 shrink-0">
          {% render 'icon-twitter' %}
        </div>
        Tweet
      </a>
    </li>
  {% endif %}
  {% if settings.share_pinterest %}
    <li>
      <a
        target="_blank"
        href="//pinterest.com/pin/create/button/?url={{ shop.url | append: share_permalink }}&amp;media={{ share_image | image_url: width: 1024, height: 1024 }}&amp;description={{ share_title | url_param_escape }}"
        rel="noopener"
        class="flex items-center text-base-body"
      >
        <div class="mr-3 w-5 shrink-0">
          {% render 'icon-pinterest' %}
        </div>
        Pin It
      </a>
    </li>
  {% endif %}
</ul>
