{% for link in linklists[section.settings.menu].links %}
  {% liquid
    assign show_second_level = false
    assign forloop_size = 0
    assign link_title = link.title | downcase
    for block in section.blocks
      assign block_title = block.settings.title | downcase
      if link_title == block_title
        assign show_second_level = true
        for item in (1..5)
          assign image = 'image_' | append: forloop.index
          if block.settings[image] != blank
            assign forloop_size = forloop.index
          endif
        endfor
      endif
    endfor
  %}
  {% if link.links != blank %}
    <li class="
        ac
        group/ac
        has-drop
        !mb-0
      ">
      <button
        type="button"
        class="
          menu-accordion__opener
          relative
          block
          w-full
          py-3
          pl-4
          pr-10
          text-left
          no-underline
          before:absolute
          before:right-4
          before:top-1/2
          before:h-[2px]
          before:w-4
          before:-translate-y-1/2
          before:rounded-sm
          before:bg-base-body
          before:content-['']
          after:absolute
          after:right-[23px]
          after:top-1/2
          after:h-4
          after:w-[2px]
          after:-translate-y-1/2
          after:rounded-sm
          after:bg-base-body
          after:transition-opacity
          after:duration-300
          after:ease-in-out
          after:content-['']
          after:group-[.is-active]/ac:opacity-0
        "
      >
        {{ link.title }}
      </button>

      <div class="ac-panel font-normal">
        <ul class="accordion js-menu-accordion px-4">
          {% for child_link in link.links %}
            {% liquid
              assign third_level_link = false
              for third_level in child_link.links
                if third_level.url != blank
                  assign third_level_link = true
                endif
              endfor
            %}
            <li class="
                ac
                group/ac-nested
                !mb-0
              ">
              {% if third_level_link %}
                <button
                  type="button"
                  class="
                    test-flag_child_link
                    menu-accordion__opener
                    relative
                    block
                    w-full
                    py-3
                    pl-2
                    pr-6
                    text-left
                    no-underline
                    before:absolute
                    before:right-0
                    before:top-1/2
                    before:h-[2px]
                    before:w-4
                    before:-translate-y-1/2
                    before:rounded-sm
                    before:bg-base-body
                    before:content-['']
                    after:absolute
                    after:right-[7px]
                    after:top-1/2
                    after:h-4
                    after:w-[2px]
                    after:-translate-y-1/2
                    after:rounded-sm
                    after:bg-base-body
                    after:transition-opacity
                    after:duration-300
                    after:ease-in-out
                    after:content-['']
                    after:group-[.is-active]/ac-nested:opacity-0
                  "
                >
                  {{ child_link.title }}
                </button>
              {% else %}
                <a
                  href="{{ child_link.url }}"
                  class="
                    menu-accordion__opener
                    relative
                    block
                    w-full
                    py-3
                    pl-2
                    pr-6
                    text-left
                    no-underline
                    before:absolute
                    before:right-0
                    before:top-1/2
                    before:h-[2px]
                    before:w-4
                    before:-translate-y-1/2
                    before:rounded-sm
                    before:content-['']
                    after:absolute
                    after:right-[7px]
                    after:top-1/2
                    after:h-4
                    after:w-[2px]
                    after:-translate-y-1/2
                    after:rounded-sm
                    after:transition-opacity
                    after:duration-300
                    after:ease-in-out
                    after:content-['']
                    after:group-[.is-active]/ac-nested:opacity-0
                  "
                >
                  {{ child_link.title }}
                </a>
              {% endif %}

              <div class="ac-panel w-full">
                {% if child_link.links != blank %}
                  <ul class="ml-2 border-l border-base-border">
                    {% for third_level in child_link.links %}
                      <li class="
                          group
                          {% if third_level.active %}
                          active
                          {% endif %}
                        ">
                        <a
                          href="{{ third_level.url }}"
                          class="block p-3 text-base-body group-[.active]:underline"
                        >
                          {{ third_level.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
        {% if show_second_level %}
          <div class="
              ml-4
              flex
              snap-x
              snap-mandatory
              gap-2
              overflow-x-auto
              overflow-y-hidden
              pr-4
              pt-3
            ">
            {% # theme-check-disable LiquidTag %}
            {% for block in section.blocks %}
              {% assign block_title_local = block.settings.title | downcase %}
              {% if link_title == block_title_local %}
                {% for item in (1..5) %}
                  {% liquid
                    assign image = 'image_' | append: forloop.index
                    assign heading = 'heading_' | append: forloop.index
                    assign text = 'text_' | append: forloop.index
                    assign block_link = 'block_url_' | append: forloop.index
                  %}
                  {% if block.settings[image] != blank %}
                    {% capture image_block %}
                      {%
                        render 'image',
                        src: block.settings[image],
                        m: '120x120',
                        crop: 'center',
                        lazyload: true,
                        fetchpriority: 'low',
                      %}
                    {% endcapture %}
                    <div class="w-30 shrink-0 snap-start">
                      {% if block.settings[block_link] != blank %}
                        <a
                          href="{{ block.settings[block_link] }}"
                          class="mb-3 block"
                        >
                          {{ image_block }}
                        </a>
                      {% else %}
                        {{ image_block }}
                      {% endif %}
                      {% if block.settings[heading] != blank %}
                        {% if block.settings[block_link] != blank %}
                          <a
                            href="{{ block.settings[block_link] }}"
                            class="block text-center font-heading text-title text-base-body"
                          >
                            {{ block.settings[heading] }}
                          </a>
                        {% else %}
                          {{ block.settings[heading] }}
                        {% endif %}
                      {% endif %}
                      {% if block.settings[text] != blank %}
                        <div class="
                            mb-3
                            flex
                            items-center
                            justify-center
                            gap-2
                            text-product-price-large
                          ">
                          <div>{{ block.settings[text] }}</div>
                        </div>
                      {% endif %}
                    </div>
                  {% else %}
                    {% continue %}
                  {% endif %}
                {% endfor %}
              {% endif %}
            {% endfor %}
            {% # theme-check-enable LiquidTag %}
          </div>
        {% endif %}
      </div>
    </li>
  {% else %}
    <li class="
        group
        {% if third_level.active %}
        active
        {% endif %}
      ">
      <a
        href="{{ link.url }}"
        class="
          block
          px-4
          py-3
          text-base-body
          group-[.active]:text-base-accent
        "
      >
        {{ link.title }}
      </a>
    </li>
  {% endif %}
{% endfor %}
