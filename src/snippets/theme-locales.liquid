<script>
  document.documentElement.className = document.documentElement.className.replace('no-js', '');

  window.theme = {
    cartState: {{ cart | json }},
    template: {{ template | json }},
    strings: {
      addToCart: {{ 'products.product.add_to_cart' | t | json }},
      addToBag: {{ 'products.product.add_to_bag' | t | json }},
      soldOut: {{ 'products.product.sold_out' | t | json }},
      unavailable: {{ 'products.product.unavailable' | t | json }}
    },
    cart: {
      // quantity: "Qty:",
      continue_shipping: "Continue shopping",
      product: {{ 'cart.label.product' | t | json }},
      price: {{ 'cart.label.price' | t | json }},
      quantity: {{ 'cart.label.quantity' | t | json }},
      total: {{ 'cart.label.total' | t | json }},
      title: {{ 'cart.general.title' | t | json }},
      empty: {{ 'cart.general.empty' | t | json }},
      continue_browsing_html: {{ 'cart.general.continue_browsing_html' | t | json }},
      note: {{ 'cart.general.note' | t | json }},
      cookies: {{ 'cart.general.cookies_required' | t | json }},
      savings: {{ 'cart.general.savings' | t | json }},
      shipping_at_checkout: {{ 'cart.general.shipping_at_checkout' | t | json }},
      checkout: {{ 'cart.general.checkout' | t | json }},
      remove: {{ 'cart.general.remove' | t | json }},
      discounted_price: {{ 'cart.label.discounted_price' | t | json }},
      original_price: {{ 'cart.label.original_price' | t | json }},
      continue_shopping_link: {{ settings.continue_shopping_link | json }},
      continue_shopping_text: {{ 'cart.general.continue_shopping_button' | t | json }},
      spend_for_free_shipping: {{ 'cart.general.spend_for_free_shipping' | t | json }},
      guarantee: {{ 'cart.general.guarantee' | t | json }},
      free_returns: {{ 'cart.general.free_returns' | t | json }},
      recommended_for_you: {{ 'cart.general.recommended_for_you' | t | json }},
      just_added_to_your_cart: {{ 'cart.general.just_added_to_your_cart' | t | json }},
      view_cart: {{ 'cart.general.view_cart' | t | json }},
      special_instructions_placeholder: {{ 'cart.general.special_instructions_placeholder' | t | json }},
      addToCart: {{ 'cart.general.add_to_cart' | t | json }},
      soldOut: {{ 'products.product.sold_out' | t | json }},
      cart_drawer_lable: {{ 'cart.general.cart_drawer_lable' | t | json }},
      subtotal: {{ 'cart.general.subtotal' | t | json }},
      free_shipping_left: {{ 'cart.general.free_shipping_left' | t | json }},
      upgrading: {{ 'cart.general.upgrading' | t | json }},
      delivery: {{ 'cart.general.delivery' | t | json }},
      subscribe: {{ 'cart.general.subscribe' | t | json }},
      subscribe_applied: {{ 'cart.general.subscribe_applied' | t | json }},
      free_shipping_riched: {{ 'cart.general.free_shipping_riched' | t | json }},
      tax_include_text: {{ 'cart.general.tax_include_text' | t | json }},
      you_may_like: {{ 'cart.general.you_may_like' | t | json }},
      shop_all_products: {{ 'cart.general.shop_all_products' | t | json }},
      CartTaxesInclude: {{ cart.taxes_included | json }},
      cartDrawer: {{ settings.cart_drawer | json }},
      showShippingIndicator: {{ settings.show_shipping_indicator | json }},
      cartTargetPrice: {{ settings.target_price | times: 100 | json }},
      cartEnableRecommendations: {{ settings.cart_recommendations_enable | json }},
      cartRecommendationsLimit: {{ settings.cart_recommendations_limit | default: 4 | json }},
      cartDrawerRecommendations: {{ settings.products | json }},
      emptyCartImage: {{ settings.empty_cart_drawer_image | json }},
      additional_checkout_buttons: {{ additional_checkout_buttons | json }},
      content_for_additional_checkout_buttons: {{ content_for_additional_checkout_buttons | json }},
      button_size: {{ settings.button_size | json }},
      showVendor: {{ settings.show_vendor | json }}
    },
    icons: {
      cart: {% render "icon", icon: 'cart', json: true %}
    },
    product: {
      regular_price: {{ 'products.product.regular_price' | t | json }},
      quantity: {{ 'products.product.quantity' | t | json }},
      color_title: {{ 'products.product.color_title' | t | json }},
      unavailable: {{ 'products.product.unavailable' | t | prepend: ' - ' | json }},
      decrease_quantity: {{ 'products.product.quantity_increase' | t | json }},
      increase_quantity: {{ 'products.product.quantity_increase' | t | json }}
    },
    placeholder_data: "data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==",
    placeholder_image: "{{ 'img-placeholder.png' | asset_img_url: 'master' }}",
    dynamic_button_placeholder: {{ 'products.product.dynamic_button_placeholder' | t | json }},
    moneyFormat: {{ shop.money_format | json }},
    published_locales: [
      {% for locale in shop.published_locales %}
      {
        name: {{ locale.name | json }},
        iso_code: {{ locale.iso_code | json }},
        root_url: {{ locale.root_url | json }},
        primary: {{ locale.primary | json }}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    published_currencies: [
      {% for country in localization.available_countries %}
        {
          country: {{ country.name | json }},
          country_iso: {{ country.iso_code | json }},
          currency: {{ country.currency.iso_code | json }},
          symbol: {{ country.currency.symbol | json }},
          {% if country.iso_code == localization.country.iso_code %}
            current: true
          {% endif %}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  };

  {% if template.directory == 'customers' %}
  theme.allCountryOptionTags = {{ all_country_option_tags | json }};
  {% endif %}
</script>
