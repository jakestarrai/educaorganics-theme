{% liquid
  assign section_onboarding = false
  if product == empty
    assign section_onboarding = true
  endif
  assign current_variant = product.selected_or_first_available_variant
  assign show_size_chart = section.settings.show_size_chart
  assign size_chart_url = section.settings.size_chart_url
  assign show_following_image = section.settings.show_following_image
  assign product_form_id = 'product-form-' | append: section.id
  assign first_image_eager = first_image_eager | default: false
%}

{% if section.settings.enable_slider %}
  <link
    rel="stylesheet"
    href="{{ 'splide-gallery.css' | asset_url }}"
    media="all"
    fetchpriority="high"
  >
  <link
    rel="stylesheet"
    href="{{ 'product-slider.css' | asset_url }}"
    media="all"
    fetchpriority="high"
  >
{% endif %}

{%- comment -%}
  Only if subscribe-block is enabled need to add this(subscribe-block.css) style file.
{%- endcomment -%}
<link
  rel="stylesheet"
  href="{{ 'subscribe-block.css' | asset_url }}"
  media="all"
  fetchpriority="high"
>

<link
  rel="stylesheet"
  href="{{ 'js-video.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<section
  data-section-id="{{ section.id }}"
  class="pb-5 md:py-7 lg:py-10"
  data-section-type="product-swatches-variants"
  data-handle="{{ product.handle }}"
>
  <div class="container max-w-screen-3xl overflow-hidden md:overflow-visible">
    <div class="pt-6 lg:flex lg:gap-10 lg:pt-0">
      <div class="
          {% if section.settings.enable_slider %}
          -mx-6
          lg:mx-0
          {% endif %}
          mb-12
          lg:mb-0
          lg:w-[52%]
          lg:shrink-0
        ">
        {% unless section_onboarding %}
          {% if section.settings.enable_slider == true %}
            <div class="lg:flex lg:items-center lg:gap-10">
              <section
                class="splide product-slider-thumbnails group/thumbnails hidden lg:block"
                aria-label="The carousel with thumbnails. Selecting a thumbnail will change the product gallery."
              >
                <div class="splide__track">
                  <ul class="splide__list flex flex-col">
                    {% render 'product-slider', product: product, current_variant: current_variant, enable_lazyload: true, slide_rounded: 'lg:rounded-[4px]', image_size_mobile: '64x', image_size_desktop: '64x', thumbnails_media: true %}
                  </ul>
                </div>
              </section>

              <section
                class="splide product-slider product-gallery-slider"
                aria-label="Product gallery"
              >
                <div class="splide__track lg:rounded-2xl">
                  <ul class="splide__list flex">
                    {% render 'product-slider', product: product, current_variant: current_variant, enable_lazyload: enable_lazyload, slide_rounded: 'max-lg:rounded-2xl', image_size_mobile: '270x', image_size_desktop: '600x' %}
                  </ul>
                </div>

                {%- comment -%}Corner element{%- endcomment -%}
                <div class="
                    pointer-events-none
                    hidden
                    lg:absolute
                    lg:right-0
                    lg:top-0
                    lg:z-4
                    lg:block
                    lg:overflow-hidden
                  ">
                  <div class="lg:-mr-[2px] lg:-mt-[2px]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="207" height="211" viewBox="0 0 207 211" fill="none">
                      <path d="M207 0V211V146.375C207 139.328 204.097 132.594 198.974 127.756L71.0944 6.99031C66.3406 2.50098 60.0497 0 53.5112 0H0L207 0Z" fill="white"/>
                    </svg>
                  </div>
                </div>
              </section>
            </div>
          {% else %}
            <div class="
                product-gallery-slider
                group
                max-md:flex
                max-md:snap-x
                max-md:snap-mandatory
                max-md:items-center
                max-md:overflow-x-auto
                max-md:overflow-y-hidden
                lg:flex
                lg:flex-wrap
                {% if show_following_image and product.media.size > 1 %}
                product-gallery-slider--alt
                max-md:-mr-[calc(var(--grid-gutter-width)/2)]
                {% endif %}
              ">
              {% render 'product-gallery', product: product, current_variant: current_variant, enable_lazyload: enable_lazyload %}
            </div>
          {% endif %}
        {% else %}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endunless %}
      </div>

      <div class="product__description lg:w-full lg:px-10">
        <div class="md:sticky md:top-[var(--header-sticky-height)]">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when "@app" %}
                <div class="mb-6 last:mb-0 lg:mb-8">
                  {% render block %}
                </div>
              {% when "title" %}
                {% liquid
                  for tag in product.tags
                    if tag contains 'usage:'
                      assign product_tag = tag | remove: 'usage:' | replace: '_', ' '
                    endif
                  endfor
                %}
                <div class="
                    mb-4
                    text-caps-s
                    uppercase
                    last:mb-0
                    lg:mb-6
                    lg:font-heading
                    lg:text-h6
                  ">
                  {{ 'products.product.infant formula_text' | t }}
                </div>
                <div class="mb-3 last:mb-0 lg:mb-5">
                  <h1 class="mb-1 font-heading text-h1 last:mb-0 lg:text-h2-desktop">{{ product.title }}</h1>
                  <div class="text-h1 font-light lg:text-h2-desktop">{{ product_tag }}</div>
                </div>
              {% when "servings" %}
                <div
                  class="overflow-hidden"
                  {{ block.shopify_attributes }}
                >
                  <ul class="
                      -mx-4
                      mb-6
                      flex
                      flex-wrap
                      gap-4
                      divide-x
                      text-body-small
                      !leading-none
                      lg:mb-8
                      lg:text-body-medium
                    ">
                    {% for item in product.metafields.product.servings.value %}
                      <li class="pl-4">{{ item }}</li>
                    {% endfor %}
                  </ul>
                </div>
              {% when "benefits" %}
                <ul
                  class="
                    mb-6
                    flex
                    flex-wrap
                    items-center
                    justify-between
                    gap-4
                    border-y
                    py-4
                    text-caps-s
                    font-medium
                    uppercase
                    last:mb-0
                    lg:mb-8
                    xl:gap-8
                  "
                  {{ block.shopify_attributes }}
                >
                  {% for item in product.metafields.product.wellness_support.value %}
                    <li class="flex max-w-[30%] items-center">
                      {% render 'icon': icon: 'checkmark-circle', class: 'mr-2 h-6 w-6 shrink-0' %}
                      {{ item }}
                    </li>
                  {% endfor %}
                </ul>
              {% when "description" %}
                <div
                  class="
                    prose
                    mb-9
                    text-body-xs
                    last:mb-0
                    lg:mb-8
                    lg:text-body-small
                  "
                  {{ block.shopify_attributes }}
                >
                  {% if product.description %}
                    {{ product.description }}
                  {% else %}
                    {{ 'homepage.onboarding.product_description' | t }}
                  {% endif %}
                </div>
              {% when "accordion" %}
                {% assign accordions = product.metafields.custom.accordions.value %}
                {% if accordions %}
                  <ul class="accordion accordion--alt js-accordion last:mb-0">
                    {% for accordion in accordions %}
                      <li class="ac">
                        <div class="font-heading text-h4 lg:text-h4-desktop">
                          <button
                            type="button"
                            class="accordion__opener ac-trigger w-full"
                            data-href="/pages/accordion"
                          >
                            {{ accordion.title }}
                          </button>
                        </div>
                        <div class="accordion__slide ac-panel">
                          <div class="
                              prose
                              overflow-hidden
                              pt-2
                              text-body-xs
                              md:pt-4
                              lg:text-body-small
                            ">
                            {{ accordion.content | metafield_tag }}
                          </div>
                        </div>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              {% when "selling_plan" %}
                {%
                  render 'product-selling-plan',
                  product: product,
                  current_variant: current_variant,
                  block: block
                %}
              {% when "collapsible_row" %}
                {% render 'product-accordion', block: block %}
              {% when "buy_buttons" %}
                {% assign target_price = settings.target_price | times: 100 | money %}
                <div class="mb-9 last:mb-0 lg:mb-8">
                  {%
                    form 'product',
                    product,
                    id: product_form_id,
                    data-product-form: '',
                    data-product-handle: product.handle,
                    data-enable-history-state: 'true',
                    data-type: 'add-to-cart-form',
                    data-test-id: 'add-to-cart'
                  %}
                    <input
                      type="hidden"
                      id="product-id"
                      name="id"
                      data-productid="{{ product.id }}"
                      value="{{ product.selected_or_first_available_variant.id }}"
                      disabled
                    >
                    <input
                      type="hidden"
                      name="selling_plan"
                      value="{{ current_selling_plan_allocation.selling_plan.id | default: '' }}"
                    >
                    <div class="mb-4">
                      {% capture button_content %}
                        <span
                          class="
                            flex
                            items-center
                            justify-center
                            divide-x
                            divide-inherit
                            text-button-small
                            lg:text-button-large
                          "
                          data-general-button-content
                        >
                          <span
                            class="inline-flex px-6 first:pl-0 last:pr-0"
                            data-price-container
                          >
                            {{ current_variant.price | money }}
                          </span>
                          <span
                            class="inline-flex px-6 first:pl-0 last:pr-0"
                            data-submit-button-text
                          >
                            {{ 'products.product.add_to_bag' | t }}
                          </span>
                        </span>
                      {% endcapture %}
                      {% if current_variant.available %}
                        {%
                          render 'button',
                          element: 'button',
                          type: 'submit',
                          class: 'w-full',
                          color: 'primary',
                          size: 'md',
                          text: button_content,
                          data_attribute: 'data-submit-button',
                          other: 'name="add"'
                        %}
                      {% else %}
                        {%
                          render 'button',
                          element: 'button',
                          type: 'submit',
                          class: 'w-full disabled',
                          color: 'primary',
                          size: 'md',
                          text: button_content,
                          data_attribute: 'data-submit-button',
                          other: 'name="add" disabled'
                        %}
                      {% endif %}
                    </div>
                    {% if settings.show_dynamic_button %}
                      <div class="mb-4 last:mb-0">
                        {{ form | payment_button }}
                      </div>
                    {% endif %}
                  {% endform %}
                  <div class="
                      flex
                      items-center
                      justify-center
                      gap-2
                      text-caps-s
                      uppercase
                    ">
                    <div>
                      {% render 'icon': icon: 'box', class: '' %}
                    </div>
                    <div>{{ 'products.product.free_shipping_text' | t: price: target_price }}</div>
                  </div>
                </div>
              {% when "variant_picker" %}
                {% unless product.has_only_default_variant %}
                  {% liquid
                    assign size_option = 'products.product.size' | t | downcase
                    assign color_option = 'products.product.flavor' | t | downcase
                  %}

                  <div
                    class="mb-9 last:mb-0 lg:mb-8"
                    data-form-id="{{ product_form_id }}"
                    {{ block.shopify_attributes }}
                    data-selects
                  >
                    {% liquid
                      assign variants_option_arr = ''
                      assign variants_availability = ''
                      for variant in product.variants
                        assign options_string = variant.options | join: '/'
                        assign variants_option_arr = variants_option_arr | append: options_string
                        assign variants_availability = variants_availability | append: variant.available
                        unless forloop.last
                          assign variants_option_arr = variants_option_arr | append: ','
                          assign variants_availability = variants_availability | append: ','
                        endunless
                      endfor
                      assign variants_option_arr = variants_option_arr | split: ','
                      assign variants_availability = variants_availability | split: ','
                      for option in product.options_with_values
                        if option.position == 1
                          assign selected_option1 = option.selected_value
                        endif
                      endfor
                    %}
                    <div data-select-holder>
                      {% for option in product.options_with_values %}
                        {% assign option_name = option.name | downcase %}
                        {% liquid
                          for value in option.values
                            for variant in product.variants
                              assign current_variant_options_string = current_variant.options | join: '/'
                              for variant_option in variant.options
                                if variant_option == value and current_variant.options[forloop.index0] == value
                                  assign current_variant_rest_options = current_variant_options_string | replace: value, '{{option_value}}'
                                  break
                                endif
                              endfor
                            endfor
                          endfor
                        %}
                        <div
                          id="variant-radios-{{ option.name }}"
                          class="
                            mb-4
                            flex
                            flex-col
                            gap-2
                            last:mb-0
                            lg:flex-row
                            lg:flex-wrap
                            lg:items-center
                          "
                          data-section="{{ section.id }}"
                          data-url="{{ product.url }}"
                          data-option-type="radio"
                          {% if option_name == color_option %}
                            data-swatches-color-type="{{ section.settings.swatches_color_type }}"
                            data-default-image="{{ product.featured_image | image_url: width: 25, height: 25 }}"
                          {% endif %}
                        >
                          <div class="uppercase">{{ option.name }}</div>
                          <div class="flex flex-wrap gap-2">
                            {% for value in option.values %}
                              {% liquid
                                if option.position != 1
                                  assign current_value_available = false
                                  for variant_option in variants_option_arr
                                    if variant_option contains selected_option1 and variant_option contains value
                                      if variants_availability[forloop.index0] == 'true'
                                        assign current_value_available = true
                                        break
                                      endif
                                    endif
                                  endfor
                                endif
                                if option.position == 1
                                  assign current_value_available = false
                                  for variant_option in variants_option_arr
                                    if variant_option contains value
                                      if variants_availability[forloop.index0] == 'true'
                                        assign current_value_available = true
                                        break
                                      endif
                                    endif
                                  endfor
                                endif
                              %}
                              <div data-option-input>
                                <label
                                  class="relative cursor-pointer overflow-hidden rounded-2xl"
                                  for="filter-field-{{ forloop.index }}-{{ option.name }}"
                                >
                                  <input
                                    type="radio"
                                    id="filter-field-{{ forloop.index }}-{{ option.name }}"
                                    class="peer pointer-events-none absolute h-full w-full rounded-2xl opacity-0"
                                    name="filter-field-{{ option.name }}"
                                    value="{{ value }}"
                                    {% if option.selected_value == value %}
                                      checked
                                    {% endif %}
                                  >
                                  <span class="
                                      flex
                                      items-center
                                      gap-3
                                      rounded-2xl
                                      border
                                      border-base-border
                                      px-4
                                      py-1
                                      transition-colors
                                      duration-300
                                      ease-in-out
                                      peer-checked:border-june-dark
                                      peer-checked:bg-june-dark
                                      peer-checked:text-white
                                    ">
                                    {% if option_name == color_option %}
                                      {% liquid
                                        assign stop_loop = false
                                        for variant in product.variants
                                          for variant_option in variant.options
                                            if variant_option == value
                                              assign variant_options_string = variant.options | join: '/'
                                              assign current_variant_options = current_variant_rest_options | replace: '{{option_value}}', value

                                              if variant_options_string == current_variant_options
                                                if section.settings.swatches_color_type == 'metafields'
                                                  if variant.metafields.swatches.color.value.value != blank
                                                    assign metafield_color = variant.metafields.swatches.color.value.value
                                                  else
                                                    assign metafield_color = value
                                                  endif
                                                else
                                                  if variant.featured_image != blank
                                                    assign image_color = variant.featured_image
                                                  else
                                                    assign image_color = product.featured_image
                                                  endif
                                                endif

                                                assign stop_loop = true
                                                break
                                              else
                                                assign image_color = product.featured_image
                                                assign metafield_color = value
                                              endif
                                            endif
                                          endfor
                                          if stop_loop
                                            break
                                          endif
                                        endfor
                                      %}
                                      {% if section.settings.swatches_color_type == 'metafields' %}
                                        <span
                                          class="
                                            js-metafield
                                            block
                                            h-4
                                            w-4
                                            shrink-0
                                            rounded-full
                                          "
                                          style="background-color: {{ metafield_color | replace: ' ', '' }};"
                                        >
                                          <span class="sr-only">Citrus Blast flavor</span>
                                        </span>
                                        <span class="text-body-xs capitalize lg:text-body-small">{{ value }}</span>
                                      {% else %}
                                        <img
                                          src="{{ image_color | image_url: width: 25, height: 25 }}"
                                          class="block h-full w-full object-cover group-[&.rounded-full]:rounded-full"
                                          width="25"
                                          height="25"
                                          alt="image description"
                                        >
                                      {% endif %}
                                    {% else %}
                                      <span class="text-body-xs capitalize lg:text-body-small">{{ value }}</span>
                                    {% endif %}
                                  </span>
                                </label>
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      {% endfor %}
                    </div>
                    <script type="application/json" data-product-vatiants>
                      {{ product.variants | json }}
                    </script>
                  </div>
                {% endunless %}
            {% endcase %}
          {% endfor %}

          {% comment %}
            <div class="subscribe-block mb-9 grid gap-4 last:mb-0 lg:mb-8">
              <div class="relative">
                <input
                  type="radio"
                  id="radio-1"
                  class="
                    subscribe-block__input
                    peer
                    pointer-events-none
                    absolute
                    h-full
                    w-full
                    opacity-0
                  "
                  checked
                  name="radio"
                >
                <div class="
                    subscribe-block__holder
                    rounded-xl
                    border
                    border-base-border
                    peer-checked:border-2
                    peer-checked:border-june-dark
                  ">
                  <label
                    for="radio-1"
                    class="
                      flex
                      cursor-pointer
                      items-center
                      justify-between
                      px-4
                      py-4
                      font-heading-weight
                    "
                  >
                    <span class="flex items-center">
                      <span class="subscribe-block__label-circle"></span>
                      <span class="flex flex-wrap items-center gap-2">
                        <span>Subscribe</span>
                        <span>
                          {% render 'icon', icon: 'refresh', class: 'w-6 h-6' %}
                        </span>
                        <span class="
                            rounded-lg
                            bg-june-dark
                            px-3
                            py-1
                            text-caps-s
                            uppercase
                            text-base-accent
                          ">
                          save 20%
                        </span>
                      </span>
                    </span>

                    <span class="flex flex-col gap-2 xl:flex-row-reverse xl:items-center max-xl:text-right">
                      <ins class="no-underline">$22.39</ins>
                      <del class="text-base-sale-price text-body-xxs">$20.39</del>
                    </span>
                  </label>
                  <div class="subscribe-block__hidden-block hidden pb-4 pl-11 pr-4 lg:pl-13">
                    <div class="prose text-body-xxs lg:text-body-xs">
                      <p>
                        Get automatic refills of your products on your schedule. No Hassle Guarantee – Skip, pause,
                        cancel, or swap out products any time.
                      </p>
                    </div>
                    <div>
                      <label
                        for="form-select-01"
                        class="sr-only"
                      >
                        Select delivery frequency
                      </label>
                      <select
                        name="form-select-01"
                        class="
                          form-select
                          h-10
                          w-full
                          rounded
                          border
                          border-june-dark
                          px-4
                          py-2
                          text-body-xs
                        "
                        id="form-select-01"
                      >
                        <option value="1">Delivers every 1 month</option>
                        <option value="2">Delivers every 2 months</option>
                        <option value="3">Delivers every 3 months</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <div class="relative">
                <input
                  type="radio"
                  id="radio-2"
                  class="
                    subscribe-block__input
                    peer
                    pointer-events-none
                    absolute
                    h-full
                    w-full
                    opacity-0
                  "
                  name="radio"
                >
                <div class="
                    subscribe-block__holder
                    rounded-xl
                    border
                    border-base-border
                    peer-checked:border-2
                    peer-checked:border-june-dark
                  ">
                  <label
                    for="radio-2"
                    class="
                      flex
                      cursor-pointer
                      items-center
                      justify-between
                      px-4
                      py-4
                      font-heading-weight
                    "
                  >
                    <span class="flex flex-wrap items-center">
                      <span class="subscribe-block__label-circle"></span>
                      <span class="mr-1">Buy once</span>
                    </span>

                    <span class="flex flex-col gap-2 lg:flex-row-reverse">
                      <span>$22.39</span>
                    </span>
                  </label>
                </div>
              </div>
            </div>
          {% endcomment %}
        </div>
      </div>
    </div>

    {% render 'pickup-availability-drawer', product: product %}
  </div>
  <script type="application/json" id="product-json">
    {% render 'product-json' %}
  </script>
</section>

<link
  rel="stylesheet"
  href="{{ 'dynamic-button.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
