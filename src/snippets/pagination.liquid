<nav
  id="pagination"
  role="navigation"
  class="pagination"
>
  <ol class="flex flex-wrap items-center justify-center">
    {%- if paginate.previous -%}
      <li class="h-11 w-11 [&.disabled]:pointer-events-none [&.disabled]:outline-none">
        <a
          href="{{ paginate.previous.url }}"
          class="
            relative
            flex
            h-full
            items-center
            justify-center
            after:absolute
            after:left-1/2
            after:top-1/2
            after:h-[9px]
            after:w-[9px]
            after:-translate-x-1/2
            after:-translate-y-1/2
            after:rotate-45
            after:border-b-[2px]
            after:border-l-[2px]
            after:border-base-icons
            after:content-['']
          "
        >
          <span class="sr-only">Previous page</span>
        </a>
      </li>
    {%- endif -%}

    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <li class="h-11 w-11 [&.disabled]:pointer-events-none [&.disabled]:outline-none">
          <a
            href="{{ part.url }}"
            class="flex h-full items-center justify-center"
          >
            {{ part.title }}
            <span class="sr-only">page</span>
          </a>
        </li>
      {%- else -%}
        {%- if part.title == paginate.current_page -%}
          <li
            class="active group h-11 w-11 [&.disabled]:pointer-events-none [&.disabled]:outline-none"
            aria-current="page"
          >
            <div class="flex h-full items-center justify-center">
              <span class="px-2 group-[&.active]:shadow-[inset_0_-1px_0_var(--base-body-text)]">
                {{ part.title }}
              </span>
              <span class="sr-only">page</span>
            </div>
          </li>
        {%- else -%}
          <li class="h-11 w-11 [&.disabled]:pointer-events-none [&.disabled]:outline-none">
            <div class="flex h-full items-center justify-center">
              <span class="px-2">
                {{ part.title }}
              </span>
              <span class="sr-only">page</span>
            </div>
          </li>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if paginate.next -%}
      <li class="h-11 w-11 [&.disabled]:pointer-events-none [&.disabled]:outline-none">
        <a
          href="{{ paginate.next.url }}"
          class="
            relative
            flex
            h-full
            items-center
            justify-center
            after:absolute
            after:left-1/2
            after:top-1/2
            after:h-[9px]
            after:w-[9px]
            after:-translate-x-1/2
            after:-translate-y-1/2
            after:rotate-[-135deg]
            after:border-b-[2px]
            after:border-l-[2px]
            after:border-base-icons
            after:content-['']
          "
        >
          <span class="sr-only">Next page</span>
        </a>
      </li>
    {%- endif -%}
  </ol>
</nav>
