{% case media.media_type %}
  {% when 'image' %}
    <div class="
        product-gallery-slider__item
        max-w-full
        max-md:w-full
        max-md:shrink-0
        max-md:snap-start
        max-md:group-[&.product-gallery-slider--alt]:w-[calc(85%+15px)]
        max-md:group-[&.product-gallery-slider--alt]:pr-[15px]
        md:pb-4
        lg:w-[calc(50%-1rem/2)]
        lg:grow
        lg:pr-4
        lg:first:w-full
      ">
      <div
        class="product-gallery-slider__img relative pt-[100%]"
        data-position="{{ media.position }}"
      >
        {%
          render 'image',
          class: 'absolute top-0 left-0 w-full h-full max-w-full object-cover',
          src: media,
          m: '345x',
          src_d: media,
          d: '673x',
          alt: media.alt,
          lazyload: lazyload,
          fetchpriority: fetchpriority_value
        %}
      </div>
    </div>
  {% when 'external_video' %}
    <div class="
        product-gallery-slider__item
        w-full
        max-w-full
        max-md:shrink-0
        max-md:snap-start
        max-md:group-[&.product-gallery-slider--alt]:w-[calc(85%+15px)]
        max-md:group-[&.product-gallery-slider--alt]:pr-[15px]
        md:pb-4
        lg:grow
        lg:pr-4
      ">
      <deferred-media
        class="
          deferred-media
          media
          product-gallery__img
          fluid-iframe
          relative
          block
          h-[0]
          overflow-hidden
          pt-[100%]
          md:pt-[56.25%]
        "
        data-media-id="{{ media.id }}"
      >
        <button
          id="Deferred-Poster-Modal-{{ media.id }}"
          class="
            deferred-media__poster
            absolute
            left-0
            top-0
            h-full
            w-full
            transition-opacity
            duration-300
            ease-in-out
          "
          type="button"
        >
          <span class="
              motion-reduce
              absolute
              left-1/2
              top-1/2
              z-1
              flex
              h-15
              w-15
              -translate-x-1/2
              -translate-y-1/2
              items-center
              justify-center
              rounded-full
              border
              border-base-body-background
              bg-base-body-background
              text-base-body
              transition-transform
              duration-300
              ease-in-out
              hover:scale-110
            ">
            {%- render 'icon', icon: 'play', class: 'w-6 h-6 ml-1' -%}
          </span>
          {%
            render 'image',
            src: media,
            m: '345x431',
            src_d: media,
            d: '635x791',
            alt: media.alt,
            lazyload: lazyload,
            fetchpriority: fetchpriority_value
          %}
        </button>
        <template>
          {%- assign video_class = 'js-' | append: media.host -%}
          {%- if media.host == 'youtube' -%}
            {{ media | external_video_url: autoplay: true, loop: loop, playlist: media.external_id | external_video_tag: class: video_class, loading: "lazy" }}
          {%- else -%}
            {{ media | external_video_url: autoplay: true, loop: loop | external_video_tag: class: video_class, loading: "lazy" }}
          {%- endif -%}
        </template>
      </deferred-media>
    </div>
  {% when 'video' %}
    <div class="
        product-gallery-slider__item
        w-full
        max-w-full
        max-md:shrink-0
        max-md:snap-start
        max-md:group-[&.product-gallery-slider--alt]:w-[calc(85%+15px)]
        max-md:group-[&.product-gallery-slider--alt]:pr-[15px]
        md:pb-4
        lg:grow
        lg:pr-4
      ">
      <div
        class="background-video-wrapper relative aspect-video"
        data-section-type="video"
        data-section-id="{{ section.id }}"
      >
        {{ media | video_tag: controls: false | replace: '<video', '<video class="js-player absolute top-0 left-0 z-1 w-full h-full object-cover" playsinline autoplay loop muted' }}
        <div class="
            pointer-events-none
            absolute
            inset-0
            z-5
            px-10
            py-5
            md:p-10
          ">
          <div class="flex h-full items-center justify-center text-center">
            <div class="video-text-block__holder sm:w-10/12 md:w-6/12 lg:w-4/12 [&>*]:pointer-events-auto">
              {% if section.settings.title %}
                {% if section.settings.text_size == 'medium' %}
                  <h2 class="font-heading text-h2 lg:text-h2-desktop">{{ section.settings.title }}</h2>
                {% else %}
                  <h2 class="font-heading text-h1 lg:text-h1-desktop">{{ section.settings.title }}</h2>
                {% endif %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% when 'model' %}
    <div class="
        product-gallery-slider__item
        w-full
        max-w-full
        max-md:shrink-0
        max-md:snap-start
        max-md:group-[&.product-gallery-slider--alt]:w-[calc(85%+15px)]
        max-md:group-[&.product-gallery-slider--alt]:pr-[15px]
        md:pb-4
        lg:grow
        lg:pr-4
      ">
      <div class="model-viewer-block relative pt-[100%]">
        <product-model class="
            deferred-media
            media
            media--transparent
            absolute
            left-0
            top-0
            block
            h-full
            w-full
            overflow-hidden
          ">
          <button
            id="Deferred-Poster-Modal-{{ media.id }}"
            class="
              deferred-media__poster
              block
              w-full
              transition-opacity
              duration-300
              ease-in-out
            "
            type="button"
          >
            <span class="
                motion-reduce
                absolute
                left-1/2
                top-1/2
                z-1
                flex
                h-15
                w-15
                -translate-x-1/2
                -translate-y-1/2
                items-center
                justify-center
                rounded-full
                border
                border-base-body-background
                bg-base-body-background
                text-base-body
                transition-transform
                duration-300
                ease-in-out
                hover:scale-110
              ">
              {%- render 'icon', icon: 'play', class: 'w-6 h-6 ml-1' -%}
            </span>
            {% if main %}
              {%
                render 'image',
                src: media,
                m: '345x431',
                src_d: media,
                d: '635x791',
                alt: media.alt,
                lazyload: lazyload,
                fetchpriority: fetchpriority_value
              %}
            {% else %}
              {%
                render 'image',
                src: media,
                m: '103x130',
                src_d: media,
                d: '191x237',
                alt: media.alt,
                lazyload: lazyload,
                fetchpriority: fetchpriority_value
              %}
            {% endif %}
          </button>
          <template>
            {%- case media.media_type -%}
              {%- when 'model' -%}
                {{ media | media_tag: image_size: "2048x", toggleable: true }}
            {%- endcase -%}
          </template>
        </product-model>
      </div>
    </div>
  {% else %}
    <div
      class="pt-[100%]"
      data-media-id="{{ media.id }}"
    >
      {{ media | media_tag }}
    </div>
{% endcase %}
