{% liquid
  assign contact_form_id = 'contact-' | append: section.id
%}
<div class="py-10">
  <div class="container max-w-screen-3xl">
    <div class="md:mx-auto md:w-10/12 xl:w-7/12">
      {% if section.settings.title != blank %}
        <h2 class="mb-10 text-h2 lg:text-h2-desktop">{{ section.settings.title }}</h2>
      {% endif %}
      {% form 'contact', id: contact_form_id %}
        {% if form.posted_successfully? %}
          <div class="form-success mb-4 text-center text-messages-success">
            {{ "contact.form.post_success" | t }}
          </div>
        {% endif %}
        {{ form.errors | default_errors }}
        <div class="md:grid md:grid-cols-2 md:gap-x-8">
          <div class="relative mb-5">
            <input
              type="text"
              id="ContactFormName-{{ section.id }}"
              class="
                peer
                form-input
                h-[52px]
                w-full
                rounded-form-element
                border-base-border
                bg-base-body-background
                pb-[5px]
                pt-[21px]
                text-body-medium
                placeholder:text-base-secondary
                placeholder:opacity-0
                autofill:shadow-inset-white
                focus:border-base-body
              "
              name="contact[name]"
              placeholder="{{ 'contact.form.name' | t }}"
              required
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            >
            <label
              for="ContactFormName-{{ section.id }}"
              class="
                absolute
                left-[13px]
                top-[14px]
                z-2
                origin-[0]
                -translate-y-2
                scale-75
                transform
                font-bold
                text-base-secondary
                duration-300
                peer-placeholder-shown:translate-y-0
                peer-placeholder-shown:scale-100
                peer-placeholder-shown:font-body-weight
                peer-focus:-translate-y-2
                peer-focus:scale-75
                peer-focus:font-bold
              "
            >
              {{ "contact.form.name" | t }}
            </label>
          </div>
          <div class="relative mb-5">
            <input
              type="email"
              id="ContactFormEmail-{{ section.id }}"
              class="
                peer
                form-input
                h-[52px]
                w-full
                rounded-form-element
                border-base-border
                bg-base-body-background
                pb-[5px]
                pt-[21px]
                text-body-medium
                placeholder:text-base-secondary
                placeholder:opacity-0
                autofill:shadow-inset-white
                focus:border-base-body
              "
              name="contact[email]"
              placeholder="{{ 'contact.form.email' | t }}"
              required
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              spellcheck="false"
              autocomplete="off"
              autocapitalize="off"
            >
            <label
              for="ContactFormEmail-{{ section.id }}"
              class="
                absolute
                left-[13px]
                top-[14px]
                z-2
                origin-[0]
                -translate-y-2
                scale-75
                transform
                font-bold
                text-base-secondary
                duration-300
                peer-placeholder-shown:translate-y-0
                peer-placeholder-shown:scale-100
                peer-placeholder-shown:font-body-weight
                peer-focus:-translate-y-2
                peer-focus:scale-75
                peer-focus:font-bold
              "
            >
              {{ "contact.form.email" | t }}
            </label>
          </div>
        </div>
        <div class="relative mb-5">
          <input
            type="tel"
            id="ContactFormPhone-{{ section.id }}"
            class="
              peer
              form-input
              h-[52px]
              w-full
              rounded-form-element
              border-base-border
              bg-base-body-background
              pb-[5px]
              pt-[21px]
              text-body-medium
              placeholder:text-base-secondary
              placeholder:opacity-0
              autofill:shadow-inset-white
              focus:border-base-body
            "
            name="contact[phone]"
            placeholder="{{ 'contact.form.phone' | t }}"
            required
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            pattern="[0-9\-]*"
          >
          <label
            for="ContactFormPhone-{{ section.id }}"
            class="
              absolute
              left-[13px]
              top-[14px]
              z-2
              origin-[0]
              -translate-y-2
              scale-75
              transform
              font-bold
              text-base-secondary
              duration-300
              peer-placeholder-shown:translate-y-0
              peer-placeholder-shown:scale-100
              peer-placeholder-shown:font-body-weight
              peer-focus:-translate-y-2
              peer-focus:scale-75
              peer-focus:font-bold
            "
          >
            {{ "contact.form.phone" | t }}
          </label>
        </div>
        <div class="relative mb-5">
          <textarea
            id="ContactFormMessage-{{ section.id }}"
            class="
              peer
              form-textarea
              max-h-[300px]
              min-h-[97px]
              w-full
              rounded-form-element
              border-base-border
              bg-base-body-background
              pt-[21px]
              text-body-medium
              placeholder:text-base-secondary
              placeholder:opacity-0
              autofill:shadow-inset-white
              focus:border-base-body
            "
            name="contact[body]"
            placeholder="{{ 'contact.form.message' | t }}"
            rows="4"
            required
          >
            {%- if form.body -%}
              {{- form.body -}}
            {%- endif -%}
          </textarea>
          <label
            for="ContactFormMessage-{{ section.id }}"
            class="
              absolute
              left-[13px]
              top-[14px]
              z-2
              origin-[0]
              -translate-y-2
              scale-75
              transform
              font-bold
              text-base-secondary
              duration-300
              peer-placeholder-shown:translate-y-0
              peer-placeholder-shown:scale-100
              peer-placeholder-shown:font-body-weight
              peer-focus:-translate-y-2
              peer-focus:scale-75
              peer-focus:font-bold
            "
          >
            {{ "contact.form.message" | t }}
          </label>
        </div>
        <div class="pt-5">
          {%
            render 'button',
            element: 'input',
            type: 'submit',
            color: 'primary',
            size: 'md',
            locales_text: 'contact.form.send'
          %}
        </div>
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Contact form",
      "label": "Heading"
    }
  ],
  "presets": [
    {
      "name": "Contact form",
      "category": "Text"
    }
  ]
}
{% endschema %}
