{% liquid
  assign blocks_size = section.blocks.size

  if section.settings.height == ''
    assign mobile_image_height = 94
    assign desktop_image_height = 125
  elsif section.settings.height == 'gallery-height-sm'
    assign mobile_image_height = 225
    assign desktop_image_height = 300
  elsif section.settings.height == 'gallery-height-md'
    assign mobile_image_height = 357
    assign desktop_image_height = 475
  elsif section.settings.height == 'gallery-height-lg'
    assign mobile_image_height = 488
    assign desktop_image_height = 650
  elsif section.settings.height == 'gallery-height-xl'
    assign mobile_image_height = 582
    assign desktop_image_height = 775
  endif

  case blocks_size
    when 1
      assign desktop_size = '1440x' | append: desktop_image_height
      assign mobile_size = '375x' | append: mobile_image_height
    when 2
      assign desktop_size = '720x' | append: desktop_image_height
      assign mobile_size = '375x' | append: mobile_image_height
    when 3
      assign desktop_size = '480x' | append: desktop_image_height
      assign mobile_size = '375x' | append: mobile_image_height
    when 4
      assign desktop_size = '360x' | append: desktop_image_height
      assign mobile_size = '375x' | append: mobile_image_height
  endcase
%}

{% if blocks_size > 0 %}
  <div class="py-10">
    <div class="mx-auto max-w-md md:max-w-none">
      <div class="md:grid md:auto-cols-fr md:grid-flow-col">
        {% for block in section.blocks %}
          {% capture gallery_image %}
            {% liquid
              if block.settings.enable_lazyload
                assign enable_lazyload = true
                assign fetchpriority_value = 'low'
              else
                assign enable_lazyload = false
                assign fetchpriority_value = 'high'
              endif

              assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1
              assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index
            %}
            <div class="
                h-[94px]
                md:h-[125px]
                [&.gallery-height-lg]:h-[488px]
                md:[&.gallery-height-lg]:h-[650px]
                [&.gallery-height-md]:h-[357px]
                md:[&.gallery-height-md]:h-[475px]
                [&.gallery-height-sm]:h-[225px]
                md:[&.gallery-height-sm]:h-[300px]
                [&.gallery-height-xl]:h-[582px]
                md:[&.gallery-height-xl]:h-[775px]
                {{ section.settings.height }}
              ">
              {% if block.settings.image != blank %}
                {%
                  render 'image',
                  class: 'object-cover h-full',
                  src: block.settings.image,
                  m: mobile_size,
                  src_d: block.settings.image,
                  d: desktop_size,
                  alt: block.settings.image.alt,
                  crop: 'center',
                  lazyload: enable_lazyload,
                  fetchpriority: fetchpriority_value
                %}
              {% else %}
                {{ placeholder_image | placeholder_svg_tag: "placeholder-svg" }}
              {% endif %}
            </div>
          {% endcapture %}
          {% capture gallery_title %}
            {% if block.settings.title %}
              <div class="
                  absolute
                  left-1/2
                  top-1/2
                  z-1
                  -translate-x-1/2
                  -translate-y-1/2
                  p-5
                  text-customizable-base
                ">
                <div class="font-heading text-h2 lg:text-h2-desktop">{{ block.settings.title }}</div>
              </div>
            {% endif %}
          {% endcapture %}
          <div {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a
                href="{{ block.settings.link }}"
                class="
                  relative
                  block
                  before:absolute
                  before:inset-0
                  before:bg-base-background
                  before:opacity-40
                  before:transition-opacity
                  before:duration-300
                  before:ease-in-out
                  before:content-['']
                  hover:before:opacity-80
                  motion-reduce:transition-none
                "
              >
                {{ gallery_image }}
                {{ gallery_title }}
              </a>
            {% else %}
              <div class="relative">
                {{ gallery_image }}
                {{ gallery_title }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Gallery",
  "settings": [
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "default": "",
      "options": [
        {
          "value": "",
          "label": "Extra small"
        },
        {
          "value": "gallery-height-sm",
          "label": "Small"
        },
        {
          "value": "gallery-height-md",
          "label": "Medium"
        },
        {
          "value": "gallery-height-lg",
          "label": "Large"
        },
        {
          "value": "gallery-height-xl",
          "label": "Extra large"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "enable_lazyload",
          "label": "Enable lazyload",
          "default": true
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Caption",
          "default": "Heading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery",
      "category": "Image",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
