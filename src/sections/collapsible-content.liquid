<section
  data-section-id="{{ section.id }}"
  class="overflow-hidden py-10 md:py-20"
>
  <div class="container max-w-screen-3xl">
    <div class="group/collapsible md:flex md:items-start {{ section.settings.image_align }}">
      {%- if section.settings.image != blank -%}
        <div class="
            mb-8
            max-md:-mx-3
            md:mb-0
            md:w-6/12
            md:shrink-0
            md:pr-10
            md:group-[.md\:flex-row-reverse]/collapsible:pl-10
            md:group-[.md\:flex-row-reverse]/collapsible:pr-0
          ">
          <div class="relative">
            {%
              render 'image',
              class: 'h-full w-full object-cover rounded-2xl',
              src:  section.settings.image,
              m: '388x308',
              src_d:  section.settings.image,
              d: '640x671',
              alt: 'image-description',
              lazyload: true,
              fetchpriority: 'low'
            %}

            {%- comment -%}Corner element{%- endcomment -%}
            <div class="pointer-events-none absolute left-0 top-0 z-4">
              <div class="-ml-[2px] -mt-[2px] xl:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" width="127" height="128" viewBox="0 0 127 128" fill="none">
                  <path d="M0.865883 0V128V97.6651C0.865883 87.7322 4.96993 78.2406 12.2067 71.4368L77.796 9.77164C84.4725 3.49465 93.2914 0 102.455 0H127L0.865883 0Z" fill="white"/>
                </svg>
              </div>
              <div class="hidden xl:-ml-[1px] xl:-mt-[1px] xl:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="338" height="343" viewBox="0 0 338 343" fill="none">
                  <path d="M0 0V343V240.755C0 227.511 5.47208 214.855 15.1212 205.784L220.142 13.0289C229.044 4.65954 240.802 0 253.021 0H338L0 0Z" fill="white"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
      {%- if section.blocks.size > 0 -%}
        <div class="md:w-full md:self-end md:pt-10 lg:pt-20 xl:px-10">
          {% if section.settings.heading != blank or section.settings.title != blank %}
            {% if section.settings.heading != blank %}
              <div class="
                  mb-6
                  text-caps-s
                  uppercase
                  lg:font-heading
                  lg:text-h6
                ">
                {{ section.settings.heading }}
              </div>
            {% endif %}
            {% if section.settings.title != blank %}
              <h2 class="mb-9 font-heading text-h2 last:mb-0 lg:text-h2-desktop">
                {{ section.settings.title }}
              </h2>
            {% endif %}
          {% endif %}
          <ul
            class="accordion js-accordion mb-9 last:mb-0{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            {% for block in section.blocks %}
              <li class="ac">
                <div class="font-heading text-h4 lg:text-h4-desktop">
                  <button
                    type="button"
                    class="accordion__opener ac-trigger w-full"
                  >
                    {{ block.settings.subtitle }}
                  </button>
                </div>
                {% if block.settings.richtext != blank %}
                  <div class="accordion__slide ac-panel">
                    <div class="
                        prose
                        overflow-hidden
                        pt-4
                        text-body-xs
                        lg:pt-6
                        lg:text-body-small
                      ">
                      {{ block.settings.richtext }}
                    </div>
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
          {% if section.settings.btn_link != blank %}
            {%
              render 'button',
              href: section.settings.btn_link,
              class: 'w-full',
              color: 'primary',
              size: 'md',
              text: section.settings.btn_text
            %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% style %}
  [data-section-id="{{ section.id }}"] {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 768px) {
    [data-section-id="{{ section.id }}"] {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Collapsible content",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Collapsible content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Caption"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image layout"
    },
    {
      "type": "select",
      "id": "image_align",
      "label": "Desktop layout",
      "options": [
        {
          "value": "md:flex-row-reverse",
          "label": "Image second"
        },
        {
          "value": "",
          "label": "Image first"
        }
      ]
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Discover The Science"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Collapsible row heading",
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "default": "Collapsible row heading",
          "label": "Block title"
        },
        {
          "type": "richtext",
          "id": "richtext",
          "default": "<p>Text</p>",
          "label": "Richtext"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "checkmark",
              "label": "Check mark"
            }
          ],
          "default": "checkmark",
          "label": "Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collapsible content",
      "category": "Image",
      "blocks": [
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
