<link
  rel="stylesheet"
  href="{{ 'splide-gallery.css' | asset_url }}"
  media="all"
  {% if section.settings.enable_lazyload %}
    fetchpriority="low"
  {% else %}
    fetchpriority="high"
  {% endif %}
>

{% if section.settings.enable_lazyload == false %}
  <link
    rel="preload"
    href="{{ section.settings.background_image | img_url: 'master' }}"
    as="image"
    fetchpriority="high"
  >
{% endif %}

{%- if section.settings.background_image != blank -%}
  <style>
    [id="our-process-{{ section.id }}"] .section-frame {
      background-image: url("{{ section.settings.background_image | img_url: 'master' }}");
      background-repeat: repeat;
    }
  </style>
{%- endif -%}

<section
  id="our-process-{{ section.id }}"
  data-section-type="our-process"
  data-section-id="{{ section.id }}"
>
  <div class="container max-w-screen-3xl px-3 xl:px-0">
    <div class="
        section-frame
        overflow-hidden
        rounded-2xl
        bg-june-dark
        text-white
        lg:rounded-b-3xl
        lg:rounded-t-2xl
      ">
      <div class="
          overflow-hidden
          px-6
          py-9
          md:px-10
          lg:px-20
          lg:pb-20
          lg:pt-30
        ">
