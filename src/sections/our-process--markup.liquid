                    group-[&.item-yellow]/text-item:border-base-accent
                    group-[&.item-dark]/text-item:bg-transparent
                    group-[&.item-yellow]/text-item:bg-base-accent
                    group-[&.item-dark]/text-item:text-base-accent
                    group-[&.item-yellow]/text-item:text-june-dark
                    lg:gap-18
                    lg:p-9
