{% liquid
  assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
  if currencies_using_comma_decimals contains cart.currency.iso_code
  endif
%}
<div class="border-t border-base-border last:border-b">
  <details-utils
    animate
    force-restore
  >
    <details
      class="js-filter group/filter-item"
      data-index="{{ forloop.index }}"
    >
      <summary class="
          flex
          cursor-pointer
          items-center
          justify-between
          py-3
          transition-all
          duration-300
          ease-in-out
          [&::-webkit-details-marker]:hidden
        ">
        {{ filter.label }}
        <span
          class="
            relative
            mx-4
            inline-block
            h-6
            w-6
            shrink-0
            before:absolute
            before:left-1/2
            before:top-1/2
            before:h-[2px]
            before:w-[64%]
            before:-translate-x-1/2
            before:-translate-y-1/2
            before:bg-current
            before:content-['']
            after:absolute
            after:left-1/2
            after:top-1/2
            after:h-[2px]
            after:w-[64%]
            after:-translate-x-1/2
            after:-translate-y-1/2
            after:rotate-90
            after:bg-current
            after:content-['']
            after:group-open/filter-item:rotate-180
            lg:ml-0
          "
        ></span>
      </summary>

      <div
        class="mb-4 overflow-hidden"
        data-filter-slide-container
      >
        <price-range class="flex items-end">
          <div class="w-full">
            <label
              for="Filter-{{ filter.min_value.param_name }}"
              class="mb-2 inline-block"
            >
              Minimum price
            </label>
            <div class="relative">
              <span class="
                  absolute
                  left-4
                  top-1/2
                  -translate-y-1/2
                  text-body-medium
                  text-base-secondary
                ">
                {{ cart.currency.symbol }}
              </span>
              <input
                type="number"
                id="Filter-{{ filter.min_value.param_name }}"
                class="
                  range-slider__input
                  form-input
                  min-h-button-md
                  w-full
                  border-base-border
                  bg-base-body-background
                  py-3
                  pl-7
                  pr-2
                  text-right
                  text-body-medium
                  leading-none
                  [appearance:textfield]
                  [&::-webkit-inner-spin-button]:appearance-none
                  [&::-webkit-outer-spin-button]:appearance-none
                "
                inputmode="numeric"
                name="{{ filter.min_value.param_name }}"
                min="0"
                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                {% if filter.min_value.value -%}
                  value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                {%- endif %}
              >
            </div>
          </div>
          <div class="mx-4 mb-3 shrink-0">to</div>
          <div class="w-full">
            <label
              for="Filter-{{ filter.max_value.param_name }}"
              class="mb-2 inline-block"
            >
              Maximum price
            </label>
            <div class="relative">
              <span class="
                  absolute
                  left-4
                  top-1/2
                  -translate-y-1/2
                  text-body-medium
                  text-base-secondary
                ">
                {{- cart.currency.symbol -}}
              </span>
              <input
                type="number"
                id="Filter-{{ filter.max_value.param_name }}"
                class="
                  range-slider__input
                  form-input
                  min-h-button-md
                  w-full
                  border-base-border
                  bg-base-body-background
                  py-3
                  pl-7
                  pr-2
                  text-right
                  text-body-medium
                  leading-none
                  [appearance:textfield]
                  [&::-webkit-inner-spin-button]:appearance-none
                  [&::-webkit-outer-spin-button]:appearance-none
                "
                inputmode="numeric"
                name="{{ filter.max_value.param_name }}"
                {% if filter.max_value.value -%}
                  value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                {%- endif %}
                min="0"
                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
              >
            </div>
          </div>
        </price-range>
      </div>
    </details>
  </details-utils>
</div>
