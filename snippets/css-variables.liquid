<style>
  {% liquid
    if settings.font_library == "shopify"
      echo settings.font_heading | font_face: font_display: 'swap'
      echo settings.font_body | font_face: font_display: 'swap'

      assign font_body_bold = settings.font_body | font_modify: 'weight', 'bold'
      assign font_body_italic = settings.font_body | font_modify: 'style', 'italic'
      assign font_body_bold_italic = font_body_bold | font_modify: 'style', 'italic'
    endif
  %}
  {% if font_body_bold or font_body_bold_italic or font_body_italic %}
    {{ font_body_bold | font_face: font_display: 'swap' }}
    {{ font_body_italic | font_face: font_display: 'swap' }}
    {{ font_body_bold_italic | font_face: font_display: 'swap' }}
  {% endif %}

  :root {
    --base-body-text: {{ settings.color_body_text }};
    --base-secondary-text: {{ settings.color_base_secondary_text }};
    --base-accent: {{ settings.color_accent }};
    --base-links: {{ settings.color_base_links }};
    --base-sale-price: {{ settings.color_base_sale_price }};
    --base-icons: {{ settings.color_base_icons }};
    --base-icons-on-hover: {{ settings.color_base_icons_on_hover }};
    --base-border: {{ settings.color_base_border }};
    --base-body-background: {{ settings.color_main_bg }};
    --base-footer-background: {{ settings.color_base_footer_background }};
    --base-background: {{ settings.color_base_background }};
    --base-overlay-dark: {{ settings.color_base_overlay_dark }};
    --base-overlay-white: {{ settings.color_base_overlay_white }};
    --june-dark: #1b1b1b;
    --june-5: #faf9f7;
    --june-red: #c8a96e;
    --jun-off-white: #f5f0eb;
    --june-fitness: #b8860b;

    /* Messages */
    --messages-error: {{ settings.color_messages_error }};
    --messages-error-light: {{ settings.color_messages_error_light }};
    --messages-success: {{ settings.color_messages_success }};
    --messages-information: {{ settings.color_messages_information }};

    /* Customizable */
    --customizable-base-text: {{ settings.customizable_base_text }};

    /* Labels */
    --labels-sale-text: {{ settings.sale_text_color }};
    --labels-sale-background: {{ settings.sale_background_color }};
    --labels-soldout-text: {{ settings.soldout_text_color }};
    --labels-soldout-background: {{ settings.soldout_background_color }};
    --labels-new-text: {{ settings.new_text_color }};
    --labels-new-background: {{ settings.new_background_color }};

    /* Font library */
    {%- case settings.font_library -%}
      {%- when 'shopify' -%}
        --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
        --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
        --font-body-weight: {{ settings.font_body.weight }};
        --font-heading-weight: {{ settings.font_heading.weight }};
        --font-body-style: {{ settings.font_body.style }};
        --font-heading-style: {{ settings.font_heading.style }};
      {%- when 'google' -%}
        --font-heading: '{{ settings.google_font_heading }}', 'Times New Roman', 'Times', 'Baskerville', 'Georgia', serif;
        --font-body: '{{ settings.google_font_body }}', 'Arial', 'Helvetica Neue', 'Helvetica', sans-serif;
        --font-body-weight: {{ settings.google_body_weight }};
        --font-heading-weight: {{ settings.google_heading_weight }};
        --font-body-style: {{ settings.google_body_style }};
        --font-heading-style: {{ settings.google_heading_style }};
      {%- when 'custom' -%}
        --font-heading: '{{ settings.custom_font_heading }}', 'Times New Roman', 'Times', 'Baskerville', 'Georgia', serif;
        --font-body: '{{ settings.custom_font_body }}', 'Arial', 'Helvetica Neue', 'Helvetica', sans-serif;
        --font-body-weight: {{ settings.custom_body_weight }};
        --font-heading-weight: {{ settings.custom_heading_weight }};
        --font-body-style: {{ settings.custom_body_style }};
        --font-heading-style: {{ settings.custom_heading_style }};
      {%- when 'hardcoded' -%}
        --font-heading: 'Halyard Display', 'Arial', 'Helvetica Neue', 'Helvetica', sans-serif;
        --font-custom-heading: 'Soulcraft', 'Arial', 'Helvetica Neue', 'Helvetica', sans-serif;
        --font-body: 'Halyard Display', 'Arial', 'Helvetica Neue', 'Helvetica', sans-serif;
        --font-body-weight: {{ settings.hardcoded_body_weight }};
        --font-heading-weight: {{ settings.hardcoded_heading_weight }};
        --font-body-style: normal;
        --font-heading-style: normal;
    {%- endcase -%}

    /* Typography */
    --font-size-base: {{ settings.font_base_size }}px;
    --heading-font-size: {{ settings.heading_base_size }}px;
    --font-body-bold-weight: {{ font_body_bold.weight | default: 'bold' }};
    --base-body-line-height: 1.25;
    --heading-line-height: 0.85;
    --base-body-letter-spacing: 0;

    /* Project variables */
    --grid-gutter-width: 40px;

    --body-min-width: 320px;
    --header-logo-width: {{ settings.logo_width }}px;
    --header-logo-width-mobile: 175px;
    --header-logo-width-desktop: 262px;
    --form-element-border-radius: {{ settings.form_element_border_radius }}px;

    --animation-speed: 0.3s;
    --menu-animation-speed: 0.2s;

    /* Primary button colors */
    --primary-button-text-color: {{ settings.button_text_color }};
    --primary-button-hover-text-color: {{ settings.button_hover_color }};
    --primary-button-focus-text-color: {{ settings.button_focus_text_color }};
    --primary-button-border-color: {{ settings.button_border_color }};
    --primary-button-hover-border-color: {{ settings.button_hover_border_color }};
    --primary-button-focus-border-color: {{ settings.button_focus_border_color }};
    --primary-button-background-color: {{ settings.button_bg_color }};
    --primary-button-hover-background-color: {{ settings.button_hover_bg_color }};
    --primary-button-focus-background-color: {{ settings.button_focus_bg_color }};
    --primary-button-text-on-disabled: {{ settings.button_text_on_disabled }};
    --primary-button-border-on-disabled: {{ settings.button_border_on_disabled }};
    --primary-button-background-on-disabled: {{ settings.button_background_on_disabled }};
    --button-border-radius: {{ settings.button_border_radius }};

    /* Secondary button colors */
    --secondary-button-text-color: {{ settings.secondary_button_text_color }};
    --secondary-button-hover-text-color: {{ settings.secondary_button_hover_text_color }};
    --secondary-button-focus-text-color: {{ settings.secondary_button_focus_text_color }};
    --secondary-button-border-color: {{ settings.secondary_button_border_color }};
    --secondary-button-hover-border-color: {{ settings.secondary_button_hover_border_color }};
    --secondary-button-focus-border-color: {{ settings.secondary_button_focus_border_color }};
    --secondary-button-background-color: {{ settings.secondary_button_background_color }};
    --secondary-button-hover-background-color: {{ settings.secondary_button_hover_background_color }};
    --secondary-button-focus-background-color: {{ settings.secondary_button_focus_background_color }};
    --secondary-button-text-on-disabled: {{ settings.secondary_button_text_on_disabled }};
    --secondary-button-border-on-disabled: {{ settings.secondary_button_border_on_disabled }};
    --secondary-button-background-on-disabled: {{ settings.secondary_button_background_on_disabled }};

    /* third button colors */
    --third-button-text-color: {{ settings.third_button_text_color }};
    --third-button-hover-text-color: {{ settings.third_button_hover_text_color }};
    --third-button-focus-text-color: {{ settings.third_button_focus_text_color }};
    --third-button-border-color: {{ settings.third_button_border_color }};
    --third-button-hover-border-color: {{ settings.third_button_hover_border_color }};
    --third-button-focus-border-color: {{ settings.third_button_focus_border_color }};
    --third-button-background-color: {{ settings.third_button_background_color }};
    --third-button-hover-background-color: {{ settings.third_button_hover_background_color }};
    --third-button-focus-background-color: {{ settings.third_button_focus_background_color }};
    --third-button-text-on-disabled: {{ settings.third_button_text_on_disabled }};
    --third-button-border-on-disabled: {{ settings.third_button_border_on_disabled }};
    --third-button-background-on-disabled: {{ settings.third_button_background_on_disabled }};

    /* Dynamic button colors */
    --dynamic-button-text-color: {{ settings.checkout_button_text_color }};
    --dynamic-button-hover-text-color: {{ settings.checkout_button_hover_color }};
    --dynamic-button-focus-text-color: {{ settings.checkout_button_focus_text_color }};
    --dynamic-button-background-color: {{ settings.checkout_button_bg_color }};
    --dynamic-button-hover-background-color: {{ settings.checkout_button_hover_bg_color }};
    --dynamic-button-focus-background-color: {{ settings.checkout_button_focus_bg_color }};
    --dynamic-button-border-color: {{ settings.checkout_button_border_color }};
    --dynamic-button-hover-border-color: {{ settings.checkout_button_hover_border_color }};
    --dynamic-button-focus-border-color: {{ settings.checkout_button_focus_border_color }};
    --dynamic-button-text-on-disabled: {{ settings.checkout_button_text_on_disabled }};
    --dynamic-button-border-on-disabled: {{ settings.checkout_button_border_on_disabled }};
    --dynamic-button-background-on-disabled: {{ settings.checkout_button_background_on_disabled }};

    /* Form settings */
    --height-form-element: 64px;
    --height-button-lg:    68px;
    --height-button-md:    64px;
    --height-button-sm:    46px;

    {% if settings.elements_outline %}
      --elements-outline: 1px dashed;
      --color-outline: {{ settings.color_outline }}
    {% endif %}
  }

  {% if settings.elements_outline %}
    * {
      outline: var(--elements-outline) var(--color-outline);
    }
  {% endif %}
</style>
